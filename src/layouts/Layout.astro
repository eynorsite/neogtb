---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = "NeoGTB — Le tiers de confiance indépendant de la GTB en France" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0F2640" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <title>{title} — NeoGTB</title>
</head>
<body class="min-h-screen bg-white text-dark-900 antialiased" style="font-family: 'Inter', system-ui, sans-serif;">

  <!-- NAV — 64px desktop, 56px mobile, hide on scroll down -->
  <header
    class="fixed top-0 w-full z-50 bg-white transition-transform duration-150 ease-out"
    style="border-bottom: 0.5px solid rgba(0,0,0,0.08);"
    id="main-header"
    x-data="{ mobileOpen: false }"
  >
    <nav class="max-w-[1200px] mx-auto px-5 md:px-10 flex items-center justify-between h-14 md:h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src="/images/logo-neogtb.png" alt="NeoGTB" class="h-10 md:h-12 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-5">
        <!-- Dropdown Comprendre -->
        <div class="relative" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
          <button class="text-[13px] font-medium text-dark-500 hover:text-dark-900 transition-colors duration-150 flex items-center gap-1">
            Comprendre
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-transition:enter="transition ease-out duration-150" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-100" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
            class="absolute top-full left-0 mt-1 w-52 bg-white rounded-lg py-2 z-50" style="border: 0.5px solid rgba(0,0,0,0.08);">
            <a href="/gtb" class={`block px-4 py-2 text-[13px] transition-colors duration-150 ${currentPath === '/gtb' ? 'text-accent-600 font-medium' : 'text-dark-500 hover:text-dark-900'}`}>Qu'est-ce que la GTB ?</a>
            <a href="/gtc" class={`block px-4 py-2 text-[13px] transition-colors duration-150 ${currentPath === '/gtc' ? 'text-accent-600 font-medium' : 'text-dark-500 hover:text-dark-900'}`}>Qu'est-ce que la GTC ?</a>
            <a href="/solutions" class={`block px-4 py-2 text-[13px] transition-colors duration-150 ${currentPath === '/solutions' ? 'text-accent-600 font-medium' : 'text-dark-500 hover:text-dark-900'}`}>Solutions & Technologies</a>
          </div>
        </div>

        <!-- Dropdown Outils -->
        <div class="relative" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
          <button class="text-[13px] font-medium text-dark-500 hover:text-dark-900 transition-colors duration-150 flex items-center gap-1">
            Outils
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-transition:enter="transition ease-out duration-150" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-100" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
            class="absolute top-full left-0 mt-1 w-52 bg-white rounded-lg py-2 z-50" style="border: 0.5px solid rgba(0,0,0,0.08);">
            <a href="/audit" class={`block px-4 py-2 text-[13px] transition-colors duration-150 ${currentPath === '/audit' ? 'text-accent-600 font-medium' : 'text-dark-500 hover:text-dark-900'}`}>Diagnostic GTB</a>
            <a href="/comparateur" class={`block px-4 py-2 text-[13px] transition-colors duration-150 ${currentPath === '/comparateur' ? 'text-accent-600 font-medium' : 'text-dark-500 hover:text-dark-900'}`}>Comparateur objectif</a>
            <a href="/generateur-cee" class={`block px-4 py-2 text-[13px] transition-colors duration-150 ${currentPath === '/generateur-cee' ? 'text-accent-600 font-medium' : 'text-dark-500 hover:text-dark-900'}`}>Générateur CEE</a>
          </div>
        </div>

        <a href="/blog" class={`text-[13px] font-medium transition-colors duration-150 ${currentPath.startsWith('/blog') ? 'text-accent-600' : 'text-dark-500 hover:text-dark-900'}`}>Perspectives</a>
        <a href="/about" class={`text-[13px] font-medium transition-colors duration-150 ${currentPath === '/about' ? 'text-accent-600' : 'text-dark-500 hover:text-dark-900'}`}>À propos</a>
      </div>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a href="/contact" class="hidden lg:inline-flex text-[12px] font-medium px-4 py-2 rounded-lg text-dark-600 transition-colors duration-150" style="border: 0.5px solid rgba(0,0,0,0.08);">Nous contacter</a>

        <!-- Hamburger -->
        <button @click="mobileOpen = !mobileOpen" class="lg:hidden p-1" aria-label="Menu">
          <svg x-show="!mobileOpen" class="w-5 h-5 text-dark-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h12M4 18h16" /></svg>
          <svg x-show="mobileOpen" class="w-5 h-5 text-dark-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div x-show="mobileOpen" x-transition:enter="transition ease-out duration-150" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-100"
      class="lg:hidden bg-white px-5 pb-5" style="border-top: 0.5px solid rgba(0,0,0,0.08);">
      <div class="flex flex-col gap-0.5 py-2">
        <span class="text-[10px] font-medium uppercase tracking-wider text-dark-400 px-3 pt-3 pb-1">Comprendre</span>
        <a href="/gtb" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">Qu'est-ce que la GTB ?</a>
        <a href="/gtc" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">Qu'est-ce que la GTC ?</a>
        <a href="/solutions" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">Solutions & Technologies</a>

        <span class="text-[10px] font-medium uppercase tracking-wider text-dark-400 px-3 pt-4 pb-1">Outils</span>
        <a href="/audit" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">Diagnostic GTB</a>
        <a href="/comparateur" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">Comparateur objectif</a>
        <a href="/generateur-cee" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">Générateur CEE</a>

        <div class="my-2" style="height: 0.5px; background: rgba(0,0,0,0.08);"></div>
        <a href="/blog" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">Perspectives</a>
        <a href="/about" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">À propos</a>
        <a href="/contact" class="text-[13px] text-dark-600 hover:text-dark-900 px-3 py-2 rounded-md transition-colors">Nous contacter</a>
      </div>
    </div>
  </header>

  <main class="pt-14 md:pt-16">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="bg-dark-950 text-white" style="border-top: 0.5px solid rgba(255,255,255,0.08);">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <!-- Brand -->
        <div class="md:col-span-2">
          <img src="/images/logo-neogtb.png" alt="NeoGTB" class="h-10 w-auto brightness-0 invert" />
          <p class="mt-4 text-[13px] text-dark-400 max-w-md" style="line-height: 1.7;">
            Le tiers de confiance indépendant de la Gestion Technique du Bâtiment en France. Aucun lien commercial avec les fabricants — nous vous aidons à comprendre, comparer et décider.
          </p>
        </div>

        <!-- Navigation -->
        <div>
          <p class="text-[10px] font-medium uppercase tracking-wider text-dark-500 mb-4">Navigation</p>
          <ul class="space-y-2">
            <li><a href="/gtb" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">GTB</a></li>
            <li><a href="/gtc" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">GTC</a></li>
            <li><a href="/solutions" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">Solutions</a></li>
            <li><a href="/comparateur" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">Comparateur</a></li>
            <li><a href="/blog" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">Perspectives</a></li>
          </ul>
        </div>

        <!-- Légal -->
        <div>
          <p class="text-[10px] font-medium uppercase tracking-wider text-dark-500 mb-4">Légal</p>
          <ul class="space-y-2">
            <li><a href="/audit" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">Diagnostic gratuit</a></li>
            <li><a href="/contact" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">Contact</a></li>
            <li><a href="/mentions-legales" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">Mentions légales</a></li>
            <li><a href="/politique-de-confidentialite" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">Confidentialité</a></li>
            <li><a href="/mes-droits-rgpd" class="text-[13px] text-dark-400 hover:text-white transition-colors duration-150">Vos droits RGPD</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3" style="border-top: 0.5px solid rgba(255,255,255,0.06);">
        <p class="text-[12px] text-dark-500">&copy; {new Date().getFullYear()} NeoGTB. Tous droits réservés.</p>
        <button onclick="window.dispatchEvent(new CustomEvent('open-cookie-settings'))" class="text-[12px] text-dark-500 hover:text-white transition-colors duration-150 cursor-pointer">Gérer les cookies</button>
      </div>
    </div>
  </footer>

  <!-- Cookie Consent -->
  <div x-data="cookieConsent()" x-cloak>
    <div x-show="showBanner" x-transition:enter="transition ease-out duration-150" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
      class="fixed bottom-0 left-0 right-0 z-[60] p-4">
      <div class="max-w-xl mx-auto bg-white rounded-lg p-5" style="border: 0.5px solid rgba(0,0,0,0.08);">
        <p class="text-[13px] font-medium text-dark-900 mb-1">Respect de votre vie privée</p>
        <p class="text-[12px] text-dark-500 mb-3" style="line-height: 1.6;">NeoGTB utilise des cookies essentiels et analytiques. Aucune donnée n'est vendue à des tiers.</p>
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[11px] font-medium text-dark-400 bg-dark-50 px-2 py-0.5 rounded">Essentiels</span>
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="checkbox" x-model="consents.analytics" class="w-3.5 h-3.5 rounded text-accent-500 focus:ring-accent-500 focus:ring-1">
            <span class="text-[11px] text-dark-600">Analytics</span>
          </label>
        </div>
        <div class="flex items-center gap-2 justify-end">
          <button @click="rejectAll()" class="text-[12px] font-medium text-dark-500 px-3 py-1.5 rounded-md bg-dark-50 transition-colors duration-150 hover:bg-dark-100">Refuser</button>
          <button @click="acceptAll()" class="text-[12px] font-medium text-white px-3 py-1.5 rounded-md bg-accent-500 transition-opacity duration-150 hover:opacity-90">Accepter</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://unpkg.com/@alpinejs/intersect@3.14.9/dist/cdn.min.js" defer></script>
  <script src="https://unpkg.com/@alpinejs/collapse@3.14.9/dist/cdn.min.js" defer></script>
  <script src="https://unpkg.com/alpinejs@3.14.9/dist/cdn.min.js" defer></script>

  <script>
    // Nav hide on scroll down, show on scroll up
    (function() {
      let lastY = 0;
      const header = document.getElementById('main-header');
      if (!header) return;
      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        if (y > 80 && y > lastY) {
          header.style.transform = 'translateY(-100%)';
        } else {
          header.style.transform = 'translateY(0)';
        }
        lastY = y;
      }, { passive: true });
    })();

    // Cookie consent
    document.addEventListener('alpine:init', () => {
      Alpine.data('cookieConsent', () => ({
        showBanner: false,
        hasConsented: false,
        consents: { analytics: false },

        init() {
          const saved = this.getCookie('neogtb_consent');
          if (saved) {
            try {
              this.consents = JSON.parse(saved);
              this.hasConsented = true;
            } catch (e) { this.showBannerDelayed(); }
          } else {
            this.showBannerDelayed();
          }
          window.addEventListener('open-cookie-settings', () => { this.showBanner = true; });
        },

        showBannerDelayed() { setTimeout(() => { this.showBanner = true; }, 800); },

        acceptAll() {
          this.consents = { analytics: true };
          this.save();
        },

        rejectAll() {
          this.consents = { analytics: false };
          this.save();
        },

        save() {
          this.setCookie('neogtb_consent', JSON.stringify(this.consents), 395);
          this.showBanner = false;
          this.hasConsented = true;
        },

        setCookie(name, value, days) {
          const d = new Date();
          d.setTime(d.getTime() + (days * 86400000));
          document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
        },

        getCookie(name) {
          const v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
          return v ? decodeURIComponent(v.pop()) : null;
        },
      }));
    });
  </script>
</body>
</html>
