---
import Layout from '../layouts/Layout.astro';
import RelatedPages from '../components/RelatedPages.astro';

const faqItems = [
  { q: "Qu'est-ce que NeoGTB ?", a: "NeoGTB est un service de conseil indépendant spécialisé dans la Gestion Technique du Bâtiment (GTB). Créé par Ulrich Calmo via la société EYNOR, NeoGTB propose des outils gratuits et des prestations de conseil payantes. NeoGTB ne vend aucun équipement." },
  { q: "Comment NeoGTB gagne-t-il de l'argent ?", a: "NeoGTB vend du conseil, pas du matériel. Les revenus proviennent exclusivement de prestations de conseil technique : audits approfondis sur site, rédaction de cahiers des charges neutres, et assistance à maîtrise d'ouvrage GTB." },
  { q: "Pourquoi les outils sont-ils gratuits ?", a: "Les outils gratuits servent à éduquer le marché et à démontrer l'approche NeoGTB. Pas de piège : pas d'inscription obligatoire, pas de relance commerciale, pas de revente de données." },
  { q: "Êtes-vous vraiment indépendant ?", a: "Oui. EYNOR, la société derrière NeoGTB, n'a aucun actionnaire fabricant, aucun partenariat commercial rémunéré, aucun lien d'affiliation." },
  { q: "Qu'est-ce que la GTB ?", a: "La Gestion Technique du Bâtiment (GTB) est un système centralisé qui pilote et supervise les équipements techniques d'un bâtiment : chauffage, ventilation, climatisation, éclairage, stores, contrôle d'accès, comptage énergie." },
  { q: "Mon bâtiment est-il concerné par le décret BACS ?", a: "Si votre bâtiment est tertiaire et que sa puissance CVC dépasse 290 kW, vous devez avoir un système BACS de classe B minimum depuis le 1er janvier 2025. Pour les bâtiments entre 70 et 290 kW, l'échéance est fixée à 2030." },
  { q: "Que signifient les classes A, B, C, D de la norme EN 15232 ?", a: "Classe D : aucune automatisation. Classe C : automatisation standard. Classe B : automatisation avancée avec supervision centralisée — niveau requis par le décret BACS. Classe A : haute performance avec optimisation énergétique et gestion prédictive." },
  { q: "Quel protocole choisir : BACnet, KNX ou Modbus ?", a: "BACnet est le standard international de la GTB pour les grands bâtiments tertiaires. KNX excelle pour l'éclairage et les stores. Modbus est simple et dominant pour le comptage énergie." },
  { q: "Combien coûte un audit GTB avec NeoGTB ?", a: "Le diagnostic en ligne est gratuit. Pour un audit approfondi sur site, les tarifs dépendent de la surface, du nombre de sites et de la complexité de l'installation." },
  { q: "Le diagnostic en ligne est-il fiable ?", a: "Le diagnostic en ligne est un outil d'orientation basé sur la norme EN 15232. Il donne une estimation de votre niveau de maturité GTB. Pour un diagnostic certifié avec mesures sur site, un audit approfondi est nécessaire." },
  { q: "Dans quelle zone géographique intervenez-vous ?", a: "Les outils en ligne sont accessibles partout. Pour les prestations sur site, j'interviens principalement en Nouvelle-Aquitaine et sur l'ensemble du territoire français selon la mission." },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
};
---

<Layout title="FAQ — Questions fréquentes sur la GTB et NeoGTB" description="Réponses aux questions les plus fréquentes sur la GTB, le décret BACS, les outils NeoGTB et notre modèle d'indépendance." jsonLd={faqJsonLd} breadcrumbs={[{label: "FAQ"}]}>

  <!-- ==================== HERO ==================== -->
  <section class="hero-lum" style="padding: 64px 0 48px;">
    <div class="hero-lum-mesh"></div>
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-lum-grid"></div>
    <div class="max-w-[1200px] mx-auto px-6 md:px-10 relative z-10">
      <div class="max-w-2xl">
        <p class="eyebrow">FAQ</p>
        <h1 style="font-size: clamp(28px, 3.5vw, 40px); font-weight: 500; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 16px;">
          Questions fréquentes
        </h1>
        <p style="font-size: 17px; color: var(--color-dark-500); line-height: 1.7; max-width: 540px;">
          Tout ce que vous devez savoir sur NeoGTB, la GTB, le décret BACS et nos outils.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ SECTIONS ==================== -->
  <section style="padding: 64px 0;">
    <div class="max-w-[720px] mx-auto px-6 md:px-10">

      <!-- Section: NeoGTB -->
      <div class="mb-12">
        <p class="eyebrow" style="margin-bottom: 24px;">À propos de NeoGTB</p>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Qu'est-ce que NeoGTB ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              NeoGTB est un service de conseil indépendant spécialisé dans la Gestion Technique du Bâtiment (GTB). Créé par Ulrich Calmo via la société EYNOR, NeoGTB propose des outils gratuits (diagnostic, comparateur, générateur CEE) et des prestations de conseil payantes (audits sur site, cahiers des charges, AMO GTB). NeoGTB ne vend aucun équipement et n'a aucun lien commercial avec les fabricants.
            </p>
          </div>
        </div>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Comment NeoGTB gagne-t-il de l'argent ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              NeoGTB vend du conseil, pas du matériel. Les revenus proviennent exclusivement de prestations de conseil technique : audits approfondis sur site, rédaction de cahiers des charges neutres, et assistance à maîtrise d'ouvrage GTB. Les outils en ligne (diagnostic, comparateur, générateur CEE) sont gratuits et le resteront. Aucune commission n'est perçue sur les ventes de matériel ou les prescriptions.
            </p>
          </div>
        </div>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Pourquoi les outils sont-ils gratuits ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              Les outils gratuits servent à éduquer le marché et à démontrer l'approche NeoGTB. Pas de piège : pas d'inscription obligatoire, pas de relance commerciale, pas de revente de données. Si après avoir utilisé les outils vous souhaitez aller plus loin avec un audit sur site, vous pouvez me contacter — mais il n'y a aucune obligation.
            </p>
          </div>
        </div>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200); border-bottom: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Êtes-vous vraiment indépendant ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              Oui. EYNOR, la société derrière NeoGTB, n'a aucun actionnaire fabricant, aucun partenariat commercial rémunéré, aucun lien d'affiliation. Les critères de comparaison sont publics et vérifiables sur le site. Si je recommande BACnet plutôt que LON pour votre projet, c'est une décision technique, pas commerciale. Vous pouvez consulter ma <a href="/positionnement" style="color: var(--color-accent-600);">charte d'indépendance</a>.
            </p>
          </div>
        </div>
      </div>

      <!-- Section: GTB & Réglementation -->
      <div class="mb-12">
        <p class="eyebrow" style="margin-bottom: 24px;">GTB & Réglementation</p>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Qu'est-ce que la GTB ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              La Gestion Technique du Bâtiment (GTB) est un système centralisé qui pilote et supervise les équipements techniques d'un bâtiment : chauffage, ventilation, climatisation (CVC), éclairage, stores, contrôle d'accès, comptage énergie. L'objectif : optimiser la consommation énergétique, améliorer le confort et faciliter la maintenance. Pour un guide complet, consultez notre page <a href="/gtb" style="color: var(--color-accent-600);">Qu'est-ce que la GTB ?</a>
            </p>
          </div>
        </div>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Mon bâtiment est-il concerné par le décret BACS ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              Si votre bâtiment est tertiaire (bureaux, commerces, enseignement, santé...) et que sa puissance CVC dépasse 290 kW, vous devez avoir un système BACS de classe B minimum depuis le 1er janvier 2025. Pour les bâtiments entre 70 et 290 kW, l'échéance est fixée à 2030. Pour les bâtiments neufs avec permis postérieur au 21/07/2021, c'est obligatoire dès la construction. <a href="/audit" style="color: var(--color-accent-600);">Faites le diagnostic gratuit</a> pour savoir où vous en êtes.
            </p>
          </div>
        </div>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Que signifient les classes A, B, C, D de la norme EN 15232 ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              La norme EN 15232 classe les systèmes de gestion technique en 4 niveaux. <strong>Classe D</strong> : aucune automatisation, pas performant. <strong>Classe C</strong> : automatisation standard, le minimum. <strong>Classe B</strong> : automatisation avancée avec supervision centralisée — c'est le niveau requis par le décret BACS. <strong>Classe A</strong> : haute performance, avec optimisation énergétique et gestion prédictive. Notre <a href="/audit" style="color: var(--color-accent-600);">diagnostic gratuit</a> vous situe sur cette échelle.
            </p>
          </div>
        </div>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200); border-bottom: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Quel protocole choisir : BACnet, KNX ou Modbus ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              Il n'y a pas de réponse universelle — ça dépend de votre contexte. <strong>BACnet</strong> est le standard international de la GTB, privilégié pour les grands bâtiments tertiaires et l'interopérabilité multi-marques. <strong>KNX</strong> excelle pour l'éclairage et les stores, avec 500+ fabricants certifiés. <strong>Modbus</strong> est simple et dominant pour le comptage énergie. Notre <a href="/comparateur" style="color: var(--color-accent-600);">comparateur</a> vous aide à y voir clair sans biais commercial.
            </p>
          </div>
        </div>
      </div>

      <!-- Section: Outils & Prestations -->
      <div class="mb-12">
        <p class="eyebrow" style="margin-bottom: 24px;">Outils & Prestations</p>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Combien coûte un audit GTB avec NeoGTB ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              Le diagnostic en ligne est gratuit, sans inscription. Pour un audit approfondi sur site avec rapport détaillé, les tarifs dépendent de la surface, du nombre de sites et de la complexité de l'installation. <a href="/contact" style="color: var(--color-accent-600);">Contactez-moi</a> avec votre contexte pour obtenir un devis. Comptez un premier échange gratuit de 15 minutes pour cadrer votre besoin.
            </p>
          </div>
        </div>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Le diagnostic en ligne est-il fiable ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              Le diagnostic en ligne est un outil d'orientation basé sur la norme EN 15232. Il donne une estimation de votre niveau de maturité GTB (classe A à D) et des recommandations générales. Pour un diagnostic certifié avec mesures sur site, un audit approfondi est nécessaire. L'outil en ligne est un excellent point de départ pour savoir si vous avez besoin d'aller plus loin.
            </p>
          </div>
        </div>

        <div x-data="{ open: false }" style="border-top: 1px solid var(--color-dark-200); border-bottom: 1px solid var(--color-dark-200);">
          <button @click="open = !open" class="w-full flex items-center justify-between py-5 text-left" style="background: none; border: none; cursor: pointer;">
            <span style="font-size: 15px; font-weight: 500; color: var(--color-dark-900);">Dans quelle zone géographique intervenez-vous ?</span>
            <svg :class="open && 'rotate-180'" class="w-4 h-4 text-dark-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" x-collapse>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7; padding-bottom: 20px;">
              Les outils en ligne sont accessibles partout. Pour les prestations sur site (audits, AMO), j'interviens principalement en Nouvelle-Aquitaine et sur l'ensemble du territoire français selon la mission. Les échanges préliminaires et le conseil à distance se font sans contrainte géographique.
            </p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div style="text-align: center; padding: 40px 0 0;">
        <p style="font-size: 16px; color: var(--color-dark-500); margin-bottom: 16px;">Vous avez une autre question ?</p>
        <a href="/contact" class="btn-primary">
          Poser ma question
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

    </div>
  </section>

  <RelatedPages links={[
    { href: "/audit", title: "Audit GTB gratuit", description: "Diagnostiquez votre bâtiment en 5 minutes." },
    { href: "/contact", title: "Contactez-nous", description: "Une question ? Réponse sous 48h, sans démarche commerciale." },
    { href: "/gtb", title: "Qu'est-ce que la GTB ?", description: "Le guide complet pour tout comprendre." },
  ]} />

</Layout>
