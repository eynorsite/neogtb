---
import Layout from '../layouts/Layout.astro';
import RelatedPages from '../components/RelatedPages.astro';
---

<Layout title="À propos — Ulrich Calmo, consultant GTB indépendant (Bordeaux)" description="NeoGTB est fondé par Ulrich Calmo, consultant indépendant en GTB basé à Eysines (Bordeaux). Aucun lien avec les fabricants, zéro commission. Parcours et méthode." breadcrumbs={[{label: "À propos"}]}>

  <!-- ==================== HERO ==================== -->
  <section class="hero-lum hero-slate">
    <div class="hero-lum-mesh"></div>
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <div class="hero-lum-grid"></div>
    <div class="max-w-[1200px] mx-auto px-6 md:px-10 relative z-10">
      <div class="max-w-2xl">
        <p class="eyebrow">À propos</p>
        <h1 style="font-size: clamp(36px, 4vw, 48px); font-weight: 500; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 20px;">
          Je suis Ulrich Calmo, et j'ai créé <span class="accent">NeoGTB</span> pour une raison simple
        </h1>
        <p style="font-size: 18px; color: var(--color-dark-500); line-height: 1.7; max-width: 560px;">
          Le marché de la GTB en France manque d'un interlocuteur neutre. Quelqu'un qui ne vend rien, qui connaît le terrain, et qui vous aide à prendre la bonne décision. C'est ce que je fais.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== FONDATEUR ==================== -->
  <section style="padding: 80px 0;">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">

        <!-- Left: créateur -->
        <div class="lg:col-span-2 reveal" x-data x-intersect.once="$el.classList.add('visible')">
          <div class="card p-8">
            <img src="/images/ulrich-calmo.webp" alt="Ulrich Calmo, créateur de la marque NeoGTB" width="120" height="120" loading="lazy" decoding="async" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin: 0 auto 20px; display: block; border: 3px solid var(--color-accent-300);" />
            <p style="font-size: 22px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 4px; text-align: center;">Ulrich Calmo</p>
            <p style="font-size: 14px; color: var(--color-accent-600); margin-bottom: 4px; text-align: center; font-weight: 500;">Fondateur de NeoGTB</p>
            <p style="font-size: 13px; color: var(--color-dark-400); margin-bottom: 20px; text-align: center;">EYNOR — Eysines, Bordeaux</p>
            <div class="sep" style="margin-bottom: 20px;"></div>

            <!-- Compétences clés -->
            <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-dark-400); margin-bottom: 12px;">Domaines d'expertise</p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
              <li class="flex items-center gap-3">
                <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent-500); flex-shrink: 0;"></div>
                <span style="font-size: 14px; color: var(--color-dark-500);">GTB / GTC / Supervision bâtiment</span>
              </li>
              <li class="flex items-center gap-3">
                <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent-500); flex-shrink: 0;"></div>
                <span style="font-size: 14px; color: var(--color-dark-500);">Protocoles : BACnet, KNX, Modbus, LON</span>
              </li>
              <li class="flex items-center gap-3">
                <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent-500); flex-shrink: 0;"></div>
                <span style="font-size: 14px; color: var(--color-dark-500);">Réglementation : décret BACS, tertiaire</span>
              </li>
              <li class="flex items-center gap-3">
                <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent-500); flex-shrink: 0;"></div>
                <span style="font-size: 14px; color: var(--color-dark-500);">Audit énergétique & AMO GTB</span>
              </li>
            </ul>

            <!-- LinkedIn -->
            <a href="https://www.linkedin.com/in/ulrich-calmo/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 mt-6" style="font-size: 14px; color: var(--color-accent-600); text-decoration: none; font-weight: 500;">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              Voir mon profil LinkedIn
            </a>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4 mt-6">
            <div class="card p-5 text-center">
              <p style="font-size: 28px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em;">10+</p>
              <p style="font-size: 12px; color: var(--color-dark-400); margin-top: 4px;">technologies analysées</p>
            </div>
            <div class="card p-5 text-center">
              <p style="font-size: 28px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em;">41</p>
              <p style="font-size: 12px; color: var(--color-dark-400); margin-top: 4px;">protocoles référencés</p>
            </div>
            <div class="card p-5 text-center">
              <p style="font-size: 28px; font-weight: 500; color: var(--color-accent-600); letter-spacing: -0.02em;">0 €</p>
              <p style="font-size: 12px; color: var(--color-dark-400); margin-top: 4px;">commission fabricant</p>
            </div>
            <div class="card p-5 text-center">
              <p style="font-size: 28px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em;">100 %</p>
              <p style="font-size: 12px; color: var(--color-dark-400); margin-top: 4px;">indépendant</p>
            </div>
          </div>
        </div>

        <!-- Right: parcours + conviction -->
        <div class="lg:col-span-3 reveal reveal-d1" x-data x-intersect.once="$el.classList.add('visible')">
          <h2 style="font-size: 28px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 24px;">Pourquoi j'ai créé NeoGTB</h2>

          <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7; margin-bottom: 16px;">
            En travaillant sur des projets de gestion technique du bâtiment, j'ai constaté un problème récurrent : <strong style="color: var(--color-dark-900); font-weight: 500;">les décideurs n'ont personne vers qui se tourner pour un avis neutre.</strong> Chaque interlocuteur vend sa solution. Les bureaux d'études prescrivent ce qu'ils connaissent. Les installateurs poussent leurs partenariats.
          </p>
          <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7; margin-bottom: 16px;">
            J'ai créé NeoGTB pour combler ce vide. Ma mission : <strong style="color: var(--color-dark-900); font-weight: 500;">éduquer le marché français sur la GTB</strong>, fournir des outils d'analyse indépendants, et permettre à chaque professionnel de comprendre, comparer et décider en connaissance de cause.
          </p>
          <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7; margin-bottom: 16px;">
            NeoGTB est une marque de ma société <strong style="color: var(--color-dark-900); font-weight: 500;">EYNOR</strong>, basée à Eysines près de Bordeaux. Je travaille seul, et c'est un choix assumé : pas d'actionnaires fabricants, pas de pression commerciale, pas de compromis sur les recommandations.
          </p>
          <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7; margin-bottom: 32px;">
            Mon seul engagement, c'est envers vous : vous donner les clés pour décider en toute connaissance de cause, sans qu'un intérêt commercial vienne fausser l'analyse.
          </p>

          <!-- Ce que je fais concrètement -->
          <div style="display: flex; flex-direction: column; gap: 14px; margin-bottom: 32px;">
            <div style="display: flex; align-items: flex-start; gap: 12px;">
              <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent-500); flex-shrink: 0; margin-top: 9px;"></div>
              <p style="font-size: 15px; color: var(--color-dark-600); line-height: 1.7; margin: 0;"><strong style="font-weight: 500; color: var(--color-dark-900);">Je fais du conseil payant, les outils sont gratuits.</strong> Mon revenu vient exclusivement de prestations de conseil — audits sur site, cahiers des charges neutres, AMO GTB.</p>
            </div>
            <div style="display: flex; align-items: flex-start; gap: 12px;">
              <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent-500); flex-shrink: 0; margin-top: 9px;"></div>
              <p style="font-size: 15px; color: var(--color-dark-600); line-height: 1.7; margin: 0;"><strong style="font-weight: 500; color: var(--color-dark-900);">Zéro lien commercial avec les fabricants.</strong> Pas de commission, pas d'affiliation, pas de partenariat rémunéré. Jamais.</p>
            </div>
            <div style="display: flex; align-items: flex-start; gap: 12px;">
              <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent-500); flex-shrink: 0; margin-top: 9px;"></div>
              <p style="font-size: 15px; color: var(--color-dark-600); line-height: 1.7; margin: 0;"><strong style="font-weight: 500; color: var(--color-dark-900);">Mes critères de comparaison sont publics.</strong> Chaque analyse est vérifiable. Si je recommande BACnet plutôt que LON, c'est technique, pas commercial.</p>
            </div>
          </div>

          <!-- Charte d'indépendance -->
          <div class="callout">
            <p class="callout-label">Ma charte d'indépendance</p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--color-accent-500);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span style="font-size: 14px; color: var(--color-dark-600); line-height: 1.6;">Aucun lien commercial avec les fabricants GTB</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--color-accent-500);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span style="font-size: 14px; color: var(--color-dark-600); line-height: 1.6;">Aucune commission sur les ventes ou prescriptions</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--color-accent-500);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span style="font-size: 14px; color: var(--color-dark-600); line-height: 1.6;">Méthodologie d'évaluation transparente et vérifiable</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--color-accent-500);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span style="font-size: 14px; color: var(--color-dark-600); line-height: 1.6;">Vos données ne sont jamais transmises à des tiers</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--color-accent-500);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span style="font-size: 14px; color: var(--color-dark-600); line-height: 1.6;">Correction ouverte en cas d'erreur factuelle</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== MÉTHODE ==================== -->
  <section style="padding: 80px 0; background: var(--color-dark-50); border-top: 1px solid var(--color-dark-200); border-bottom: 1px solid var(--color-dark-200);">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10">
      <div class="max-w-xl mb-12 reveal" x-data x-intersect.once="$el.classList.add('visible')">
        <p class="eyebrow">Mon approche</p>
        <h2 style="font-size: 28px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 12px;">Ma méthode — 4 phases</h2>
        <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7;">Une approche structurée pour accompagner chaque projet GTB, du diagnostic à la mise en oeuvre.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="card p-6 reveal" x-data x-intersect.once="$el.classList.add('visible')">
          <p style="font-size: 40px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em;">01</p>
          <h3 style="font-size: 15px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 8px;">État des lieux</h3>
          <p style="font-size: 13px; color: var(--color-dark-500); line-height: 1.6;">J'audite l'existant : équipements en place, protocoles utilisés, niveau d'intégration, points de friction.</p>
        </div>
        <div class="card p-6 reveal reveal-d1" x-data x-intersect.once="$el.classList.add('visible')">
          <p style="font-size: 40px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em;">02</p>
          <h3 style="font-size: 15px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 8px;">Analyse comparative</h3>
          <p style="font-size: 13px; color: var(--color-dark-500); line-height: 1.6;">J'évalue les solutions disponibles. Comparaison par critères objectifs : interopérabilité, coût, évolutivité.</p>
        </div>
        <div class="reveal reveal-d2 p-6" x-data x-intersect.once="$el.classList.add('visible')" style="background: white; border-radius: 12px; border: 1px solid var(--color-accent-200); box-shadow: 0 0 0 3px var(--color-accent-50);">
          <p style="font-size: 40px; font-weight: 500; color: var(--color-accent-400); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em;">03</p>
          <h3 style="font-size: 15px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 8px;">Recommandations</h3>
          <p style="font-size: 13px; color: var(--color-dark-500); line-height: 1.6;">Je vous livre une synthèse argumentée. Chaque recommandation est justifiée, traçable et libre de conflit d'intérêts.</p>
        </div>
        <div class="card p-6 reveal reveal-d3" x-data x-intersect.once="$el.classList.add('visible')">
          <p style="font-size: 40px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em;">04</p>
          <h3 style="font-size: 15px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 8px;">Accompagnement</h3>
          <p style="font-size: 13px; color: var(--color-dark-500); line-height: 1.6;">Je suis la mise en oeuvre, vérifie la conformité et transfère les compétences à vos équipes internes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="relative overflow-hidden" style="padding: 80px 0; background: #F0F2F5; min-height: 360px; border-top: 1px solid var(--color-dark-200);">
    <img src="/images/hero-gtb-illustration.webp" alt="" aria-hidden="true" loading="lazy" style="position: absolute; right: 13%; top: 50%; transform: translateY(-50%); height: 110%; max-width: 55%; object-fit: contain; object-position: right center; opacity: 0.55; pointer-events: none;" />
    <div style="position: absolute; inset: 0; background: linear-gradient(to right, #F0F2F5 30%, rgba(240,242,245,0.3) 70%); pointer-events: none;"></div>
    <div class="max-w-[1200px] mx-auto px-6 md:px-10 relative z-10" style="display: flex; align-items: center; min-height: 200px;">
      <div style="max-width: 520px;">
        <h2 style="font-size: 28px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 12px;">Un projet GTB à clarifier ?</h2>
        <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7; margin-bottom: 28px;">Échangeons sur votre situation. Sans engagement, sans pression commerciale.</p>
        <a href="/contact" class="btn-primary">
          Me contacter directement
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <RelatedPages links={[
    { href: "/positionnement", title: "Pourquoi NeoGTB ?", description: "Les preuves de notre indépendance totale." },
    { href: "/contact", title: "Contactez Ulrich", description: "Discutons de votre projet GTB sans engagement." },
    { href: "/audit", title: "Audit GTB gratuit", description: "Diagnostiquez votre bâtiment en 5 minutes." },
  ]} />

</Layout>
