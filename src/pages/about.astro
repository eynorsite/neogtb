---
import Layout from '../layouts/Layout.astro';
---

<Layout title="A propos — NeoGTB" description="NeoGTB, le tiers de confiance indépendant de la GTB en France. Marque de EURL EYNOR, basée à Eysines près de Bordeaux.">

  <style>
    /* About page — design system connaissance */
    .about-hero {
      padding: 64px 0 48px;
      background: #fff;
    }
    .about-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
    }
    .eyebrow {
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #9A9AAA;
      margin-bottom: 12px;
    }
    .about-hero h1 {
      font-size: 28px;
      font-weight: 500;
      color: #0F0F0F;
      line-height: 1.2;
      letter-spacing: -0.5px;
      margin-bottom: 14px;
      max-width: 640px;
    }
    .about-hero .subtitle {
      font-size: 15px;
      color: #5A5A6A;
      line-height: 1.7;
      max-width: 560px;
    }
    .sep {
      height: 0.5px;
      background: rgba(0, 0, 0, 0.08);
      margin: 0;
    }

    /* Two columns identity + mission */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 48px;
      align-items: start;
      padding: 48px 0;
    }
    .founder-photo {
      background: #F7F7F9;
      border-radius: 12px;
      border: 0.5px solid rgba(0, 0, 0, 0.08);
      aspect-ratio: 3 / 4;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .founder-avatar {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: #EEEDFE;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      font-weight: 500;
      color: #3C3489;
    }
    .founder-meta .founder-name {
      font-size: 15px;
      font-weight: 500;
      color: #0F0F0F;
      margin-bottom: 2px;
    }
    .founder-meta .founder-title {
      font-size: 12px;
      color: #5A5A6A;
    }
    .founder-sep {
      height: 0.5px;
      background: rgba(0, 0, 0, 0.08);
      margin: 12px 0;
    }
    .founder-creds {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 0;
      margin: 0;
    }
    .founder-creds li {
      font-size: 12px;
      color: #5A5A6A;
      padding-left: 12px;
      position: relative;
    }
    .founder-creds li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 6px;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: #534AB7;
    }

    .about-text h2 {
      font-size: 22px;
      font-weight: 500;
      color: #0F0F0F;
      line-height: 1.25;
      letter-spacing: -0.3px;
      margin-bottom: 16px;
    }
    .about-text p {
      font-size: 14px;
      color: #5A5A6A;
      line-height: 1.7;
      margin-bottom: 14px;
    }

    /* Charte callout */
    .callout {
      background: #F7F7F9;
      border: 0.5px solid rgba(0, 0, 0, 0.08);
      border-radius: 12px;
      padding: 24px;
      margin-top: 32px;
    }
    .callout-title {
      font-size: 14px;
      font-weight: 500;
      color: #0F0F0F;
      margin-bottom: 14px;
    }
    .callout ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .callout li {
      font-size: 13px;
      color: #5A5A6A;
      line-height: 1.6;
      padding-left: 16px;
      position: relative;
    }
    .callout li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 7px;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #534AB7;
    }

    /* Stats grid 2x2 */
    .about-stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 28px;
    }
    .about-stat {
      background: #F7F7F9;
      border-radius: 8px;
      padding: 14px;
      border: 0.5px solid rgba(0, 0, 0, 0.08);
    }
    .stat-n {
      display: block;
      font-size: 22px;
      font-weight: 500;
      color: #0F0F0F;
      letter-spacing: -0.3px;
    }
    .stat-l {
      display: block;
      font-size: 11px;
      color: #5A5A6A;
      margin-top: 3px;
    }

    /* Methodology */
    .methodology {
      padding: 64px 0;
      border-top: 0.5px solid rgba(0, 0, 0, 0.08);
    }
    .methodology h2 {
      font-size: 22px;
      font-weight: 500;
      color: #0F0F0F;
      letter-spacing: -0.3px;
      margin-bottom: 6px;
    }
    .method-sub {
      font-size: 14px;
      color: #5A5A6A;
      margin-bottom: 28px;
    }
    .method-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }
    .method-step {
      border: 0.5px solid rgba(0, 0, 0, 0.08);
      border-radius: 12px;
      padding: 18px;
      transition: border-color 0.15s ease;
    }
    .method-step:hover {
      border-color: rgba(0, 0, 0, 0.15);
    }
    .method-step--active {
      border-left: 2px solid #534AB7;
      border-radius: 0 12px 12px 0;
    }
    .step-num {
      font-size: 32px;
      font-weight: 500;
      color: #EEEDFE;
      margin-bottom: 10px;
      line-height: 1;
    }
    .step-num--active {
      color: #534AB7;
    }
    .method-step h3 {
      font-size: 13px;
      font-weight: 500;
      color: #0F0F0F;
      margin-bottom: 8px;
    }
    .method-step p {
      font-size: 12px;
      color: #5A5A6A;
      line-height: 1.6;
    }

    /* CTA */
    .cta-section {
      padding: 64px 0;
      border-top: 0.5px solid rgba(0, 0, 0, 0.08);
      text-align: center;
    }
    .cta-section h2 {
      font-size: 22px;
      font-weight: 500;
      color: #0F0F0F;
      letter-spacing: -0.3px;
      margin-bottom: 8px;
    }
    .cta-section p {
      font-size: 14px;
      color: #5A5A6A;
      line-height: 1.7;
      margin-bottom: 24px;
    }
    .btn-primary {
      display: inline-block;
      font-size: 13px;
      font-weight: 500;
      padding: 10px 24px;
      border-radius: 8px;
      background: #534AB7;
      color: #EEEDFE;
      text-decoration: none;
      transition: background 0.15s ease;
    }
    .btn-primary:hover {
      background: #3C3489;
    }

    @media (max-width: 768px) {
      .about-inner {
        padding: 0 20px;
      }
      .about-hero {
        padding: 40px 0 32px;
      }
      .about-grid {
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 40px 0;
      }
      .founder-photo {
        aspect-ratio: auto;
        padding: 40px;
      }
      .method-grid {
        grid-template-columns: 1fr 1fr;
      }
      .methodology,
      .cta-section {
        padding: 40px 0;
      }
    }
  </style>

  <!-- Hero -->
  <section class="about-hero">
    <div class="about-inner">
      <p class="eyebrow">A propos</p>
      <h1>Le tiers de confiance independant de la GTB en France</h1>
      <p class="subtitle">NeoGTB fournit aux gestionnaires de batiments, bureaux d'etudes et decideurs une information GTB fiable, objective et sans pression commerciale. Nous ne vendons rien — nous aidons a decider.</p>
    </div>
  </section>

  <div class="about-inner"><div class="sep"></div></div>

  <!-- Two columns: identity + mission -->
  <section>
    <div class="about-inner">
      <div class="about-grid">
        <!-- Left: brand identity -->
        <div class="about-visual">
          <div class="founder-photo">
            <div class="founder-avatar">N</div>
          </div>
          <div class="founder-meta">
            <div class="founder-name">NeoGTB</div>
            <div class="founder-title">Marque de EURL EYNOR</div>
            <div class="founder-sep"></div>
            <ul class="founder-creds">
              <li>EURL EYNOR</li>
              <li>Eysines, Bordeaux</li>
              <li>Conseil independant en GTB</li>
              <li>Aucune attache fabricant</li>
            </ul>
          </div>
        </div>

        <!-- Right: mission + conviction + stats -->
        <div class="about-text">
          <h2>Notre conviction : chaque gestionnaire de batiment devrait pouvoir prendre des decisions GTB eclairees, sans pression commerciale</h2>
          <p>La GTB est un levier majeur pour reduire la consommation energetique des batiments tertiaires et industriels. Pourtant, le marche francais reste domine par des acteurs qui orientent systematiquement vers leurs propres produits. Il n'existait aucun tiers de confiance capable d'accompagner les decideurs sans conflit d'interets.</p>
          <p>NeoGTB est ne de ce constat. Notre mission : eduquer le marche francais sur la GTB, fournir des outils d'analyse independants, et permettre a chaque professionnel de comprendre, comparer et decider en connaissance de cause. Nous analysons les technologies, les protocoles et les solutions disponibles avec une seule grille de lecture : l'interet du batiment et de ses occupants.</p>
          <p>NeoGTB est une marque de EURL EYNOR, societe basee a Eysines pres de Bordeaux. Cette structure garantit notre independance : aucune participation capitalistique de fabricants, aucune commission sur les ventes, aucune pression commerciale sur nos recommandations.</p>

          <!-- Stats grid 2x2 -->
          <div class="about-stats">
            <div class="about-stat">
              <span class="stat-n">10+</span>
              <span class="stat-l">technologies analysees</span>
            </div>
            <div class="about-stat">
              <span class="stat-n">4 protocoles</span>
              <span class="stat-l">maitrises (BACnet, KNX, Modbus, LON)</span>
            </div>
            <div class="about-stat">
              <span class="stat-n">0 &euro;</span>
              <span class="stat-l">commission fabricant</span>
            </div>
            <div class="about-stat">
              <span class="stat-n">100 %</span>
              <span class="stat-l">independant</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="about-inner"><div class="sep"></div></div>

  <!-- Charte d'independance -->
  <section>
    <div class="about-inner" style="padding-top: 48px; padding-bottom: 48px;">
      <div class="callout">
        <div class="callout-title">Charte d'independance NeoGTB</div>
        <ul>
          <li>Aucun lien commercial avec les fabricants GTB</li>
          <li>Aucune commission sur les ventes ou prescriptions</li>
          <li>Methodologie d'evaluation transparente et verifiable</li>
          <li>Donnees utilisateurs jamais transmises a des tiers</li>
          <li>Correction ouverte en cas d'erreur factuelle</li>
        </ul>
      </div>
    </div>
  </section>

  <div class="about-inner"><div class="sep"></div></div>

  <!-- La methode NeoGTB -->
  <section class="methodology">
    <div class="about-inner">
      <p class="eyebrow">Notre approche</p>
      <h2>La methode NeoGTB — 4 phases</h2>
      <p class="method-sub">Une approche structuree pour accompagner chaque projet GTB, du diagnostic a la mise en oeuvre.</p>
      <div class="method-grid">
        <div class="method-step">
          <div class="step-num">01</div>
          <h3>Etat des lieux</h3>
          <p>Audit de l'existant : equipements en place, protocoles utilises, niveau d'integration, points de friction. Cartographie complete du systeme technique du batiment.</p>
        </div>
        <div class="method-step">
          <div class="step-num">02</div>
          <h3>Analyse comparative</h3>
          <p>Evaluation neutre des solutions disponibles sur le marche. Comparaison par criteres objectifs : interoperabilite, cout total, evolutivite, conformite reglementaire.</p>
        </div>
        <div class="method-step method-step--active">
          <div class="step-num step-num--active">03</div>
          <h3>Recommandations</h3>
          <p>Synthese argumentee adaptee au contexte specifique du batiment. Chaque recommandation est justifiee, tracable et libre de tout conflit d'interet commercial.</p>
        </div>
        <div class="method-step">
          <div class="step-num">04</div>
          <h3>Accompagnement</h3>
          <p>Suivi de la mise en oeuvre, verification de la conformite des livrables, transfert de competences aux equipes internes pour une autonomie durable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="about-inner">
      <h2>Un projet GTB a clarifier ?</h2>
      <p>Echangeons sur votre situation. Sans engagement, sans pression commerciale.</p>
      <a href="/contact" class="btn-primary">Prendre contact</a>
    </div>
  </section>

</Layout>
