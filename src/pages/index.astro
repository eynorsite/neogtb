---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tiers de confiance indépendant GTB" description="NeoGTB : le tiers de confiance indépendant de la GTB en France. Nous ne vendons rien, nous vous aidons à comprendre, comparer et décider en toute objectivité. Diagnostic gratuit, comparateur objectif, veille réglementaire.">

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden min-h-[92vh] flex items-center" style="background: linear-gradient(135deg, #091829 0%, #0F2640 40%, #1B3A5C 100%);">
    <!-- Animated background elements -->
    <div class="absolute inset-0">
      <div class="absolute top-20 left-10 w-72 h-72 bg-accent-500/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-cyan-500/8 rounded-full blur-3xl animate-float-slow"></div>
      <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-accent-500/5 rounded-full blur-3xl"></div>
      <!-- Circuit grid pattern overlay -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 48px 48px;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 w-full text-white">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text content -->
        <div>
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold bg-accent-500/15 text-accent-300 border border-accent-500/25 mb-6 backdrop-blur-sm">
            <span class="w-2 h-2 bg-accent-400 rounded-full animate-pulse"></span>
            Tiers de confiance indépendant
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-extrabold leading-[1.1]">
            Le <span class="text-gradient">tiers de confiance</span> indépendant de la <span class="text-gradient">GTB</span> en France
          </h1>
          <p class="mt-6 text-lg md:text-xl text-dark-300 max-w-xl leading-relaxed">
            Nous ne vendons rien. Nous ne représentons aucune marque. Nous vous aidons à <strong class="text-white font-semibold">comprendre, comparer et décider</strong> en toute objectivité.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a href="/audit" class="btn-cta inline-flex items-center justify-center gap-2 px-7 py-3.5 text-base">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
              Diagnostiquer mon bâtiment
            </a>
            <a href="/comparateur" class="btn-outline inline-flex items-center justify-center gap-2 px-7 py-3.5 text-base">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
              Comparer les technologies
            </a>
          </div>
          <!-- Trust badges -->
          <div class="mt-10 flex items-center gap-6 sm:gap-8 text-sm">
            <div class="flex items-center gap-2 text-dark-300">
              <div class="w-9 h-9 rounded-lg bg-accent-500/15 flex items-center justify-center border border-accent-500/20">
                <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
              <span>Indépendant</span>
            </div>
            <div class="flex items-center gap-2 text-dark-300">
              <div class="w-9 h-9 rounded-lg bg-cyan-500/15 flex items-center justify-center border border-cyan-500/20">
                <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
              </div>
              <span>Objectif</span>
            </div>
            <div class="flex items-center gap-2 text-dark-300">
              <div class="w-9 h-9 rounded-lg bg-accent-500/15 flex items-center justify-center border border-accent-500/20">
                <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <span>Gratuit</span>
            </div>
          </div>
        </div>

        <!-- Right: Hero Image -->
        <div class="hidden lg:block relative">
          <div class="relative w-full max-w-lg mx-auto">
            <div class="absolute inset-0 bg-gradient-to-t from-accent-500/15 to-transparent rounded-3xl blur-2xl"></div>
            <img src="/images/hero-building.png" alt="Bâtiment intelligent avec GTB — supervision, capteurs IoT et tableau de bord énergétique" class="w-full relative z-10 drop-shadow-2xl rounded-2xl animate-float-slow" />
          </div>
        </div>
      </div>
    </div>

    <!-- Diagonal separator hero → white -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none" class="w-full h-16 md:h-20"><path d="M0 80V40L720 0L1440 40V80H0Z" fill="white"/></svg>
    </div>
  </section>

  <!-- ==================== OUTILS INTERACTIFS ==================== -->
  <section class="py-24 relative bg-white" x-data="{ shown: false }" x-intersect.once="shown = true">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-accent-50 text-accent-700 border border-accent-200 mb-4">Nos outils gratuits</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-900">Comprenez, comparez, <span class="text-gradient">décidez</span></h2>
        <p class="mt-4 text-lg text-dark-500 max-w-2xl mx-auto">Trois outils exclusifs pour vous accompagner dans vos choix GTB, en toute indépendance.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Card 1: Diagnostic -->
        <a href="/audit" class="group relative p-8 bg-white rounded-2xl border border-dark-200 card-hover-glow overflow-hidden opacity-0 shadow-sm" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 0ms'">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent-500 to-accent-400 rounded-t-2xl"></div>
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-accent-50 to-transparent rounded-bl-full opacity-60 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-primary-700 rounded-2xl flex items-center justify-center mb-5 shadow-lg shadow-primary-500/20 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h3 class="text-xl font-heading font-bold text-dark-900 group-hover:text-primary-600 transition-colors">Diagnostic GTB</h3>
            <p class="mt-3 text-dark-500 text-sm leading-relaxed">Évaluez la maturité technique de votre bâtiment en 8 questions. Résultat immédiat avec score et recommandations.</p>
            <div class="mt-5 flex items-center gap-2 text-sm font-semibold text-primary-600">
              <span>Lancer le diagnostic</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>

        <!-- Card 2: Comparateur -->
        <a href="/comparateur" class="group relative p-8 bg-white rounded-2xl border border-dark-200 card-hover-glow overflow-hidden opacity-0 shadow-sm" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 150ms'">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-cyan-500 to-primary-500 rounded-t-2xl"></div>
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-cyan-50 to-transparent rounded-bl-full opacity-60 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="w-14 h-14 bg-gradient-to-br from-accent-500 to-accent-700 rounded-2xl flex items-center justify-center mb-5 shadow-lg shadow-accent-500/20 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <h3 class="text-xl font-heading font-bold text-dark-900 group-hover:text-accent-600 transition-colors">Comparateur objectif</h3>
            <p class="mt-3 text-dark-500 text-sm leading-relaxed">10 marques GTB analysées avec scores, forces et faiblesses. Filtrez par protocole, budget et taille de bâtiment.</p>
            <div class="mt-5 flex items-center gap-2 text-sm font-semibold text-accent-600">
              <span>Comparer les marques</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>

        <!-- Card 3: Générateur CEE -->
        <a href="/generateur-cee" class="group relative p-8 bg-white rounded-2xl border border-dark-200 card-hover-glow overflow-hidden opacity-0 shadow-sm" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 300ms'">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-yellow-500 to-orange-500 rounded-t-2xl"></div>
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-yellow-50 to-transparent rounded-bl-full opacity-60 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="w-14 h-14 bg-gradient-to-br from-yellow-500 to-orange-500 rounded-2xl flex items-center justify-center mb-5 shadow-lg shadow-yellow-500/20 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="text-xl font-heading font-bold text-dark-900 group-hover:text-orange-600 transition-colors">Générateur CEE</h3>
            <p class="mt-3 text-dark-500 text-sm leading-relaxed">Estimez vos Certificats d'Économies d'Énergie en 3 minutes. Calcul indépendant, aucune commission.</p>
            <div class="mt-5 flex items-center gap-2 text-sm font-semibold text-orange-600">
              <span>Estimer mes CEE</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Diagonal: white → gray -->
  <div class="relative -mt-1"><svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-10 md:h-14"><path d="M0 0H1440V20L720 60L0 20V0Z" fill="white"/></svg></div>

  <!-- ==================== GTB / GTC ==================== -->
  <section class="py-24 bg-dark-50 relative overflow-hidden" x-data="{ shown: false }" x-intersect.once="shown = true">
    <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-900">Comprendre la <span class="text-gradient">GTB</span> et la <span class="text-gradient">GTC</span></h2>
        <p class="mt-4 text-lg text-dark-500 max-w-2xl mx-auto">Deux systèmes complémentaires pour une gestion intelligente et performante de vos bâtiments.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- GTB Card -->
        <a href="/gtb" class="group block bg-white rounded-2xl border border-dark-200 card-hover-glow overflow-hidden opacity-0" :class="shown && 'animate-fade-in-left'" :style="shown && 'animation-delay: 0ms'">
          <div class="h-2 bg-gradient-to-r from-primary-500 to-primary-700"></div>
          <div class="p-8">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-primary-700 rounded-2xl flex items-center justify-center shadow-lg shadow-primary-500/20">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              </div>
              <div>
                <h3 class="text-2xl font-heading font-bold text-dark-900 group-hover:text-primary-600 transition-colors">Gestion Technique du Bâtiment</h3>
                <span class="text-xs font-medium text-primary-600 bg-primary-50 px-2 py-0.5 rounded">GTB</span>
              </div>
            </div>
            <p class="text-dark-500 leading-relaxed">La GTB supervise et pilote l'ensemble des équipements techniques : CVC, éclairage, sécurité, contrôle d'accès. Elle optimise confort et énergie grâce à l'automatisation intelligente.</p>
            <div class="mt-6 flex items-center gap-4 text-xs text-dark-400">
              <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> CVC</span>
              <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Éclairage</span>
              <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Sécurité</span>
              <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Énergie</span>
            </div>
            <span class="inline-flex items-center mt-6 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">
              Explorer la GTB <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <!-- GTC Card -->
        <a href="/gtc" class="group block bg-white rounded-2xl border border-dark-200 card-hover-glow overflow-hidden opacity-0" :class="shown && 'animate-fade-in-right'" :style="shown && 'animation-delay: 150ms'">
          <div class="h-2 bg-gradient-to-r from-accent-500 to-accent-700"></div>
          <div class="p-8">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-500 to-accent-700 rounded-2xl flex items-center justify-center shadow-lg shadow-accent-500/20">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
              </div>
              <div>
                <h3 class="text-2xl font-heading font-bold text-dark-900 group-hover:text-accent-600 transition-colors">Gestion Technique Centralisée</h3>
                <span class="text-xs font-medium text-accent-600 bg-accent-50 px-2 py-0.5 rounded">GTC</span>
              </div>
            </div>
            <p class="text-dark-500 leading-relaxed">La GTC centralise la supervision de tous les systèmes techniques via une interface unique. Surveillance en temps réel, alarmes, historiques et reporting automatisé.</p>
            <div class="mt-6 flex items-center gap-4 text-xs text-dark-400">
              <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Temps réel</span>
              <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Alarmes</span>
              <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Multi-sites</span>
              <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Reporting</span>
            </div>
            <span class="inline-flex items-center mt-6 text-sm font-semibold text-accent-600 group-hover:gap-2 transition-all">
              Explorer la GTC <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Diagonal: gray → white -->
  <div class="relative -mt-1"><svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-10 md:h-14 bg-white"><path d="M0 0H1440V20L720 60L0 20V0Z" fill="#F5F7FA"/></svg></div>

  <!-- ==================== POURQUOI NEOGTB ==================== -->
  <section class="py-24 relative overflow-hidden bg-white" x-data="{ shown: false }" x-intersect.once="shown = true">
    <!-- Decorative background -->
    <div class="absolute top-0 left-0 w-96 h-96 bg-accent-100/30 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-cyan-100/30 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-accent-50 text-accent-700 border border-accent-200 mb-4">Ce qui nous différencie</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-900">Pourquoi faire confiance à <span class="text-gradient">NeoGTB</span> ?</h2>
        <p class="mt-4 text-lg text-dark-500 max-w-2xl mx-auto">Dans un marché où chaque acteur vend son propre matériel, NeoGTB est le seul à vous conseiller sans arrière-pensée commerciale.</p>
      </div>

      <div class="hidden md:grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Colonne "Les autres acteurs" -->
        <div class="bg-white rounded-2xl border border-dark-200 p-8 shadow-sm">
