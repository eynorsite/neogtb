---
import Layout from '../layouts/Layout.astro';
import homepageData from '../data/homepage.json';
const { hero } = homepageData;
---

<Layout title="Tiers de confiance indépendant de la GTB" description="NeoGTB est le tiers de confiance indépendant de la Gestion Technique du Bâtiment en France. Diagnostic gratuit, comparateur objectif, veille réglementaire — sans lien commercial avec aucun fabricant.">

  <!-- ==================== HERO ==================== -->
  <section class="hero-img" style="position: relative; min-height: 520px; display: flex; align-items: center; overflow: hidden;">
    <img
      src={hero.image}
      alt={hero.image_alt}
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center;"
    />
    <div style="position: absolute; inset: 0; background: linear-gradient(to left, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.45) 50%, rgba(0,0,0,0.15) 100%);"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-10 relative z-10" style="width: 100%;">
      <div style="max-width: 560px; margin-left: auto;">
        <p style="display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.1); backdrop-filter: blur(8px); padding: 5px 14px; border-radius: 20px; border: 0.5px solid rgba(255,255,255,0.15); margin-bottom: 24px;">
          {hero.badge}
        </p>

        <p style="font-size: 22px; font-weight: 500; color: rgba(255,255,255,0.7); letter-spacing: -0.02em; margin-bottom: 12px;">
          Néo<span style="font-weight: 500; color: #fff;">GTB</span>
        </p>

        <h1 style="font-size: clamp(32px, 4.5vw, 48px); font-weight: 500; line-height: 1.12; letter-spacing: -0.03em; color: #fff; margin-bottom: 20px;">
          {hero.title}
        </h1>

        <p style="font-size: 15px; color: rgba(255,255,255,0.65); line-height: 1.7; max-width: 440px; margin-bottom: 32px;">
          {hero.description}
        </p>

        <div class="flex flex-wrap items-center gap-4">
          <a href={hero.cta_url} class="btn-primary">
            {hero.cta_text}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href={hero.cta2_url} style="font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.6); text-decoration: none; transition: color 0.15s;">
            {hero.cta2_text} →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CREDIBILITY BAR ==================== -->
  <section style="padding: 24px 0; border-bottom: 1px solid var(--color-dark-200);">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10">
      <div class="hidden md:flex items-center justify-center gap-16">
        <img src="/images/logos/partenaires/logo-siemens.svg" alt="Siemens" class="h-7 grayscale opacity-25 hover:opacity-50 transition-opacity" />
        <img src="/images/logos/partenaires/logo-schneider.svg" alt="Schneider Electric" class="h-7 grayscale opacity-25 hover:opacity-50 transition-opacity" />
        <img src="/images/logos/partenaires/logo-honeywell.svg" alt="Honeywell" class="h-7 grayscale opacity-25 hover:opacity-50 transition-opacity" />
        <img src="/images/logos/partenaires/logo-sauter.svg" alt="Sauter" class="h-7 grayscale opacity-25 hover:opacity-50 transition-opacity" />
        <img src="/images/logos/partenaires/logo-knx.svg" alt="KNX" class="h-7 grayscale opacity-25 hover:opacity-50 transition-opacity" />
        <img src="/images/logos/partenaires/logo-watchdog.png" alt="TheWatchdog" class="h-7 grayscale opacity-25 hover:opacity-50 transition-opacity" />
      </div>
      <div class="md:hidden flex gap-10 overflow-x-auto scrollbar-hide snap-x">
        <img src="/images/logos/partenaires/logo-siemens.svg" alt="Siemens" class="h-5 grayscale opacity-25 snap-center flex-shrink-0" />
        <img src="/images/logos/partenaires/logo-schneider.svg" alt="Schneider Electric" class="h-5 grayscale opacity-25 snap-center flex-shrink-0" />
        <img src="/images/logos/partenaires/logo-honeywell.svg" alt="Honeywell" class="h-5 grayscale opacity-25 snap-center flex-shrink-0" />
        <img src="/images/logos/partenaires/logo-sauter.svg" alt="Sauter" class="h-5 grayscale opacity-25 snap-center flex-shrink-0" />
        <img src="/images/logos/partenaires/logo-knx.svg" alt="KNX" class="h-5 grayscale opacity-25 snap-center flex-shrink-0" />
        <img src="/images/logos/partenaires/logo-watchdog.png" alt="TheWatchdog" class="h-5 grayscale opacity-25 snap-center flex-shrink-0" />
      </div>
    </div>
  </section>

  <!-- ==================== POSITIONING ==================== -->
  <section style="padding: 96px 0;">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10">
      <div class="max-w-xl mb-16 reveal" x-data x-intersect.once="$el.classList.add('visible')">
        <p class="eyebrow">Ce que nous faisons</p>
        <h2 style="font-size: clamp(28px, 3vw, 36px); font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 12px;">Trois outils pour éclairer vos décisions GTB</h2>
        <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7;">Gratuit, sans engagement, sans orientation commerciale vers une marque ou un protocole.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <a href="/audit" class="card block p-8 reveal" x-data x-intersect.once="$el.classList.add('visible')" style="text-decoration: none;">
          <p style="font-size: 48px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 20px; letter-spacing: -0.03em;">01</p>
          <h3 style="font-size: 18px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 10px; letter-spacing: -0.01em;">Évaluez la maturité de votre bâtiment</h3>
          <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7;">Diagnostic en 8 questions basé sur la norme EN 15232. Score immédiat, recommandations par niveau A à D.</p>
          <p style="margin-top: 20px; font-size: 14px; font-weight: 500; color: var(--color-accent-600);">Lancer le diagnostic →</p>
        </a>

        <a href="/comparateur" class="card block p-8 reveal reveal-d1" x-data x-intersect.once="$el.classList.add('visible')" style="text-decoration: none;">
          <p style="font-size: 48px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 20px; letter-spacing: -0.03em;">02</p>
          <h3 style="font-size: 18px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 10px; letter-spacing: -0.01em;">Comparez les technologies sans biais</h3>
          <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7;">10 fabricants GTB analysés sur des critères objectifs : protocoles, ouverture, coût, scalabilité.</p>
          <p style="margin-top: 20px; font-size: 14px; font-weight: 500; color: var(--color-accent-600);">Comparer les marques →</p>
        </a>

        <a href="/generateur-cee" class="card block p-8 reveal reveal-d2" x-data x-intersect.once="$el.classList.add('visible')" style="text-decoration: none;">
          <p style="font-size: 48px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 20px; letter-spacing: -0.03em;">03</p>
          <h3 style="font-size: 18px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 10px; letter-spacing: -0.01em;">Estimez vos aides CEE en 3 minutes</h3>
          <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.7;">Calcul basé sur les fiches BAT-TH-116 et BAT-TH-112. Estimation indépendante, sans intermédiaire.</p>
          <p style="margin-top: 20px; font-size: 14px; font-weight: 500; color: var(--color-accent-600);">Estimer mes CEE →</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== METHODOLOGY ==================== -->
  <section style="padding: 96px 0; background: var(--color-dark-50); border-top: 1px solid var(--color-dark-200); border-bottom: 1px solid var(--color-dark-200);">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10">
      <div class="max-w-xl mb-16 reveal" x-data x-intersect.once="$el.classList.add('visible')">
        <p class="eyebrow">Notre approche</p>
        <h2 style="font-size: clamp(28px, 3vw, 36px); font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 12px;">La méthode NeoGTB — 4 phases</h2>
        <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7;">Une approche structurée et reproductible, calibrée sur les exigences du décret BACS et de la norme EN 15232.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="card p-6 reveal" x-data x-intersect.once="$el.classList.add('visible')">
          <p style="font-size: 40px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em;">01</p>
          <h3 style="font-size: 15px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 8px;">État des lieux</h3>
          <p style="font-size: 13px; color: var(--color-dark-500); line-height: 1.6;">Cartographie des équipements, protocoles en place, évaluation du niveau EN 15232.</p>
        </div>
        <div class="card p-6 reveal reveal-d1" x-data x-intersect.once="$el.classList.add('visible')">
          <p style="font-size: 40px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em;">02</p>
          <h3 style="font-size: 15px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 8px;">Analyse comparative</h3>
          <p style="font-size: 13px; color: var(--color-dark-500); line-height: 1.6;">Solutions du marché adaptées au contexte : taille, protocoles, budget, contraintes.</p>
        </div>
        <div class="reveal reveal-d2 p-6" x-data x-intersect.once="$el.classList.add('visible')" style="background: white; border-radius: 12px; border: 1px solid var(--color-accent-200); box-shadow: 0 0 0 3px var(--color-accent-50);">
          <p style="font-size: 40px; font-weight: 500; color: var(--color-accent-400); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em;">03</p>
          <h3 style="font-size: 15px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 8px;">Recommandations</h3>
          <p style="font-size: 13px; color: var(--color-dark-500); line-height: 1.6;">Préconisations chiffrées : ROI, gains énergétiques, calendrier de conformité BACS.</p>
        </div>
        <div class="card p-6 reveal reveal-d3" x-data x-intersect.once="$el.classList.add('visible')">
          <p style="font-size: 40px; font-weight: 500; color: var(--color-dark-200); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em;">04</p>
          <h3 style="font-size: 15px; font-weight: 500; color: var(--color-dark-900); margin-bottom: 8px;">Accompagnement</h3>
          <p style="font-size: 13px; color: var(--color-dark-500); line-height: 1.6;">Suivi de mise en oeuvre, vérification performances réelles, transfert de compétences.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CASE STUDIES ==================== -->
  <section style="padding: 96px 0;">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10">
      <div class="max-w-xl mb-16 reveal" x-data x-intersect.once="$el.classList.add('visible')">
        <p class="eyebrow">Cas d'usage</p>
        <h2 style="font-size: clamp(28px, 3vw, 36px); font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; line-height: 1.15;">Des situations concrètes, des résultats mesurables</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="card p-8 reveal" x-data x-intersect.once="$el.classList.add('visible')">
          <div class="flex items-center gap-3 mb-6">
            <span class="tag tag-reglementation">Décret BACS</span>
            <span style="font-size: 13px; color: var(--color-dark-400);">Tertiaire · 12 000 m²</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; margin-bottom: 12px; line-height: 1.3;">Mise en conformité BACS d'un ensemble de bureaux multi-sites</h3>
          <p style="font-size: 15px; color: var(--color-dark-500); line-height: 1.7; margin-bottom: 20px;">Un gestionnaire de 3 sites tertiaires devait se conformer au décret BACS. Aucune GTB en place, systèmes CVC hétérogènes.</p>
          <div style="border-left: 2px solid var(--color-accent-500); padding-left: 16px; margin-bottom: 24px;">
            <p style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-dark-400); margin-bottom: 6px;">Approche</p>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.6;">Audit EN 15232 sur 3 sites, benchmark 4 solutions multi-protocoles, estimation CEE, cahier des charges neutre.</p>
          </div>
          <div class="grid grid-cols-3 gap-4">
            <div style="padding: 14px; border-radius: 8px; background: var(--color-dark-50);">
              <p style="font-size: 22px; font-weight: 500; color: var(--color-accent-600); letter-spacing: -0.02em;">C → B</p>
              <p style="font-size: 11px; color: var(--color-dark-400); margin-top: 4px;">niveau EN 15232</p>
            </div>
            <div style="padding: 14px; border-radius: 8px; background: var(--color-dark-50);">
              <p style="font-size: 22px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em;">-23 %</p>
              <p style="font-size: 11px; color: var(--color-dark-400); margin-top: 4px;">conso CVC</p>
            </div>
            <div style="padding: 14px; border-radius: 8px; background: var(--color-dark-50);">
              <p style="font-size: 22px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em;">45 j</p>
              <p style="font-size: 11px; color: var(--color-dark-400); margin-top: 4px;">cahier des charges</p>
            </div>
          </div>
        </div>

        <div class="card p-8 reveal reveal-d1" x-data x-intersect.once="$el.classList.add('visible')">
          <div class="flex items-center gap-3 mb-6">
            <span class="tag tag-technique">Rénovation CVC</span>
            <span style="font-size: 13px; color: var(--color-dark-400);">Enseignement · 8 500 m²</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; margin-bottom: 12px; line-height: 1.3;">Optimisation énergétique d'un campus universitaire vieillissant</h3>
          <p style="font-size: 15px; color: var(--color-dark-500); line-height: 1.7; margin-bottom: 20px;">Un campus équipé d'une GTC obsolète (LON). Consommation supérieure de 40 % à la moyenne du secteur éducatif.</p>
          <div style="border-left: 2px solid var(--color-accent-500); padding-left: 16px; margin-bottom: 24px;">
            <p style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-dark-400); margin-bottom: 6px;">Approche</p>
            <p style="font-size: 14px; color: var(--color-dark-500); line-height: 1.6;">Diagnostic complet, analyse migration LON → BACnet IP, comparaison de 3 superviseurs, simulation des gains par lot.</p>
          </div>
          <div class="grid grid-cols-3 gap-4">
            <div style="padding: 14px; border-radius: 8px; background: var(--color-dark-50);">
              <p style="font-size: 22px; font-weight: 500; color: var(--color-accent-600); letter-spacing: -0.02em;">D → B</p>
              <p style="font-size: 11px; color: var(--color-dark-400); margin-top: 4px;">niveau visé</p>
            </div>
            <div style="padding: 14px; border-radius: 8px; background: var(--color-dark-50);">
              <p style="font-size: 22px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em;">-35 %</p>
              <p style="font-size: 11px; color: var(--color-dark-400); margin-top: 4px;">objectif réduction</p>
            </div>
            <div style="padding: 14px; border-radius: 8px; background: var(--color-dark-50);">
              <p style="font-size: 22px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em;">3 ans</p>
              <p style="font-size: 11px; color: var(--color-dark-400); margin-top: 4px;">ROI estimé</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== INSIGHTS ==================== -->
  <section style="padding: 96px 0; background: var(--color-dark-50); border-top: 1px solid var(--color-dark-200); border-bottom: 1px solid var(--color-dark-200);">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10">
      <div class="flex items-end justify-between mb-12 reveal" x-data x-intersect.once="$el.classList.add('visible')">
        <div>
          <p class="eyebrow">Perspectives</p>
          <h2 style="font-size: clamp(28px, 3vw, 36px); font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; line-height: 1.15;">Analyses & veille technique</h2>
        </div>
        <a href="/blog" class="hidden md:inline-flex btn-ghost">Tous les articles →</a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <a href="/blog/decret-tertiaire-gtb-obligations" class="card block overflow-hidden reveal" x-data x-intersect.once="$el.classList.add('visible')" style="text-decoration: none;">
          <div style="height: 140px; background: linear-gradient(135deg, #ECFDF5, var(--color-accent-50));"></div>
          <div class="p-6">
            <span class="tag tag-reglementation" style="margin-bottom: 12px;">Réglementation</span>
            <h3 style="font-size: 16px; font-weight: 500; color: var(--color-dark-900); line-height: 1.4; margin-top: 12px;">Décret tertiaire et GTB : obligations et mise en conformité</h3>
            <p style="font-size: 13px; color: var(--color-dark-400); margin-top: 12px;">8 min de lecture</p>
          </div>
        </a>

        <a href="/blog/protocoles-communication-bacnet-knx-modbus" class="card block p-6 reveal reveal-d1" x-data x-intersect.once="$el.classList.add('visible')" style="text-decoration: none;">
          <span class="tag tag-protocoles">Protocoles</span>
          <h3 style="font-size: 16px; font-weight: 500; color: var(--color-dark-900); line-height: 1.4; margin-top: 16px;">BACnet, KNX, Modbus : quel protocole pour quel usage en GTB ?</h3>
          <p style="font-size: 13px; color: var(--color-dark-400); margin-top: 12px;">6 min de lecture</p>
        </a>

        <a href="/blog/guide-complet-gtb-2026" class="card block p-6 reveal reveal-d2" x-data x-intersect.once="$el.classList.add('visible')" style="text-decoration: none;">
          <span class="tag tag-gtb">Guide</span>
          <h3 style="font-size: 16px; font-weight: 500; color: var(--color-dark-900); line-height: 1.4; margin-top: 16px;">Qu'est-ce que la GTB ? Le guide complet 2026</h3>
          <p style="font-size: 13px; color: var(--color-dark-400); margin-top: 12px;">5 min de lecture</p>
        </a>
      </div>

      <a href="/blog" class="md:hidden btn-ghost mt-8">Tous les articles →</a>
    </div>
  </section>

  <!-- ==================== TESTIMONIALS ==================== -->
  <section style="padding: 96px 0;">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10">
      <div class="max-w-xl mb-16 reveal" x-data x-intersect.once="$el.classList.add('visible')">
        <p class="eyebrow">Retours terrain</p>
        <h2 style="font-size: clamp(28px, 3vw, 36px); font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; line-height: 1.15;">Ce qu'en disent les professionnels</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="card p-8 reveal" x-data x-intersect.once="$el.classList.add('visible')">
          <blockquote style="font-size: 15px; color: var(--color-dark-600); font-style: italic; line-height: 1.7; font-family: Georgia, serif; margin: 0 0 24px 0;">
            "Le comparateur nous a permis de challenger notre intégrateur sur des critères qu'on n'aurait pas identifiés seuls. On a économisé 3 mois de cadrage."
          </blockquote>
          <div class="sep" style="margin-bottom: 16px;"></div>
          <div class="flex items-center gap-3">
            <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--color-accent-50); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; color: var(--color-accent-700);">ML</div>
            <div>
              <p style="font-size: 14px; font-weight: 500; color: var(--color-dark-900);">M. Lefèvre</p>
              <p style="font-size: 12px; color: var(--color-dark-400);">Resp. technique, groupe tertiaire · 45 sites</p>
            </div>
          </div>
        </div>

        <div class="card p-8 reveal reveal-d1" x-data x-intersect.once="$el.classList.add('visible')">
          <blockquote style="font-size: 15px; color: var(--color-dark-600); font-style: italic; line-height: 1.7; font-family: Georgia, serif; margin: 0 0 24px 0;">
            "Enfin un acteur qui ne cherche pas à nous vendre sa solution. Le diagnostic a posé un cadre clair pour notre mise en conformité BACS."
          </blockquote>
          <div class="sep" style="margin-bottom: 16px;"></div>
          <div class="flex items-center gap-3">
            <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--color-dark-100); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; color: var(--color-dark-600);">SC</div>
            <div>
              <p style="font-size: 14px; font-weight: 500; color: var(--color-dark-900);">S. Chabert</p>
              <p style="font-size: 12px; color: var(--color-dark-400);">Dir. patrimoine, collectivité · 22 bâtiments</p>
            </div>
          </div>
        </div>

        <div class="card p-8 reveal reveal-d2" x-data x-intersect.once="$el.classList.add('visible')">
          <blockquote style="font-size: 15px; color: var(--color-dark-600); font-style: italic; line-height: 1.7; font-family: Georgia, serif; margin: 0 0 24px 0;">
            "L'analyse comparative a mis en lumière des écarts de coût de 40 % entre deux solutions équivalentes sur le papier."
          </blockquote>
          <div class="sep" style="margin-bottom: 16px;"></div>
          <div class="flex items-center gap-3">
            <div style="width: 36px; height: 36px; border-radius: 50%; background: #EEF2FF; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; color: #4338CA;">PD</div>
