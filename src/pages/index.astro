---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tiers de confiance indépendant GTB" description="NeoGTB : le tiers de confiance indépendant de la GTB en France. Nous ne vendons rien, nous vous aidons à comprendre, comparer et décider en toute objectivité. Diagnostic gratuit, comparateur objectif, veille réglementaire.">

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary-900 via-primary-800 to-dark-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-accent-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-20 w-96 h-96 bg-primary-400 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-accent-500/20 text-accent-300 border border-accent-500/30 mb-6">
          Tiers de confiance indépendant
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-extrabold leading-tight">
          Le <span class="text-accent-400">tiers de confiance</span> indépendant de la GTB en France
        </h1>
        <p class="mt-6 text-lg md:text-xl text-dark-300 max-w-2xl">
          Nous ne vendons rien. Nous ne représentons aucune marque. Nous vous aidons à comprendre, comparer et décider en toute objectivité.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/audit" class="inline-flex items-center justify-center px-6 py-3 bg-accent-500 text-white font-semibold rounded-lg hover:bg-accent-600 transition-colors">
            Diagnostiquer mon bâtiment
          </a>
          <a href="/comparateur" class="inline-flex items-center justify-center px-6 py-3 bg-white/10 text-white font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-colors">
            Comparer les technologies
          </a>
        </div>
        <div class="mt-8 flex items-center gap-6 text-sm text-dark-400">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Indépendant
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Objectif
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Gratuit
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Qu'est-ce que la GTB/GTC -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-900">Comprendre la GTB et la GTC</h2>
        <p class="mt-4 text-lg text-dark-500 max-w-2xl mx-auto">
          Deux systèmes complémentaires pour une gestion intelligente et performante de vos bâtiments.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- GTB Card -->
        <a href="/gtb" class="group block p-8 bg-white rounded-2xl border border-dark-200 hover:border-primary-300 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-2xl font-heading font-bold text-dark-900 group-hover:text-primary-600 transition-colors">
            Gestion Technique du Bâtiment
          </h3>
          <p class="mt-3 text-dark-500">
            La GTB supervise et pilote l'ensemble des équipements techniques d'un bâtiment : CVC, éclairage, sécurité, contrôle d'accès. Découvrez comment elle optimise confort et énergie.
          </p>
          <span class="inline-flex items-center mt-4 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">
            En savoir plus
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>

        <!-- GTC Card -->
        <a href="/gtc" class="group block p-8 bg-white rounded-2xl border border-dark-200 hover:border-accent-300 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-accent-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
            </svg>
          </div>
          <h3 class="text-2xl font-heading font-bold text-dark-900 group-hover:text-accent-600 transition-colors">
            Gestion Technique Centralisée
          </h3>
          <p class="mt-3 text-dark-500">
            La GTC centralise la supervision de tous les systèmes techniques via une interface unique. Surveillance en temps réel, alarmes, historiques et reporting automatisé.
          </p>
          <span class="inline-flex items-center mt-4 text-sm font-semibold text-accent-600 group-hover:gap-2 transition-all">
            En savoir plus
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Section Pourquoi NEOGTB — Tiers de confiance -->
  <section class="py-20 bg-dark-50" x-data="{ shown: false }" x-intersect.once="shown = true">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-primary-100 text-primary-700 mb-4">
          Ce qui nous différencie
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-900">Pourquoi faire confiance à NeoGTB ?</h2>
        <p class="mt-4 text-lg text-dark-500 max-w-2xl mx-auto">
          Dans un marché où chaque acteur vend son propre matériel, NeoGTB est le seul à vous conseiller sans arrière-pensée commerciale.
        </p>
      </div>

      <!-- Desktop : tableau comparatif côte à côte -->
      <div class="hidden md:grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Colonne "Les autres acteurs" -->
        <div class="bg-white rounded-2xl border border-dark-200 p-8">
          <h3 class="text-lg font-heading font-bold text-dark-400 mb-6 uppercase tracking-wide">Les autres acteurs GTB</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 100ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-100 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </span>
              <p class="text-dark-600">Vendent leur propre matériel et logiciel</p>
            </div>
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 200ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-100 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </span>
              <p class="text-dark-600">Intérêt commercial biaisé vers leurs solutions</p>
            </div>
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 300ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-100 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </span>
              <p class="text-dark-600">Spécialistes d'un seul protocole ou d'une seule marque</p>
            </div>
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 400ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-100 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </span>
              <p class="text-dark-600">Vision produit : vous vendent une solution, pas une stratégie</p>
            </div>
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 500ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-100 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </span>
              <p class="text-dark-600">Tarification opaque, devis obligatoire pour tout savoir</p>
            </div>
          </div>
        </div>

        <!-- Colonne "NEOGTB" -->
        <div class="bg-gradient-to-br from-primary-600 to-primary-800 rounded-2xl p-8 text-white shadow-xl shadow-primary-600/20">
          <h3 class="text-lg font-heading font-bold text-primary-200 mb-6 uppercase tracking-wide">NeoGTB — Tiers de confiance</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 150ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <p class="text-primary-100">Indépendant de toute marque et de tout fabricant</p>
            </div>
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 250ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <p class="text-primary-100">Conseil objectif garanti, aucun conflit d'intérêts</p>
            </div>
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 350ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <p class="text-primary-100">Maîtrise multi-protocoles : BACnet, KNX, Modbus, LON</p>
            </div>
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 450ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <p class="text-primary-100">Vision performance globale, pas de vente de produits</p>
            </div>
            <div class="flex items-start gap-3 opacity-0" :class="shown && 'animate-fade-in-up'" :style="shown && 'animation-delay: 550ms'">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <p class="text-primary-100">Outils gratuits et transparents pour décider vous-même</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile : accordéon -->
      <div class="md:hidden space-y-4" x-data="{ openPanel: 'neogtb' }">
        <!-- NEOGTB (ouvert par défaut) -->
        <div class="bg-gradient-to-br from-primary-600 to-primary-800 rounded-xl overflow-hidden shadow-lg">
          <button @click="openPanel = openPanel === 'neogtb' ? '' : 'neogtb'" class="w-full flex items-center justify-between p-5 text-white">
            <span class="font-heading font-bold">NeoGTB — Tiers de confiance</span>
            <svg class="w-5 h-5 transition-transform" :class="openPanel === 'neogtb' && 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="openPanel === 'neogtb'" x-collapse class="px-5 pb-5 space-y-3">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-300 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-primary-100">Indépendant de toute marque et fabricant</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-300 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-primary-100">Conseil objectif, aucun conflit d'intérêts</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-300 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-primary-100">Maîtrise multi-protocoles</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-300 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-primary-100">Vision performance globale</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-300 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-primary-100">Outils gratuits et transparents</p>
            </div>
          </div>
        </div>

        <!-- Autres acteurs -->
        <div class="bg-white rounded-xl border border-dark-200 overflow-hidden">
          <button @click="openPanel = openPanel === 'others' ? '' : 'others'" class="w-full flex items-center justify-between p-5 text-dark-900">
            <span class="font-heading font-bold text-dark-400">Les autres acteurs GTB</span>
            <svg class="w-5 h-5 text-dark-400 transition-transform" :class="openPanel === 'others' && 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="openPanel === 'others'" x-collapse class="px-5 pb-5 space-y-3">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-red-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              <p class="text-sm text-dark-600">Vendent leur propre matériel</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-red-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              <p class="text-sm text-dark-600">Intérêt commercial biaisé</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-red-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              <p class="text-sm text-dark-600">Un seul protocole ou marque</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-red-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              <p class="text-sm text-dark-600">Vision produit, pas stratégie</p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-red-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              <p class="text-sm text-dark-600">Tarification opaque</p>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center mt-12">
        <a href="/about" class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors group">
          Découvrir notre charte d'indépendance
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Chiffres clés — repositionnés tiers de confiance -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-900">Le marché GTB en France</h2>
        <p class="mt-4 text-lg text-dark-500">Les chiffres qui justifient un tiers de confiance indépendant</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-heading font-extrabold text-primary-600">84%</div>
          <p class="mt-2 text-sm text-dark-500">des bâtiments tertiaires non conformes au décret BACS</p>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-heading font-extrabold text-accent-500">300M€</div>
          <p class="mt-2 text-sm text-dark-500">marché de la GTB en France</p>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-heading font-extrabold text-primary-600">18</div>
          <p class="mt-2 text-sm text-dark-500">technologies analysées en toute indépendance</p>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-heading font-extrabold text-accent-500">0</div>
          <p class="mt-2 text-sm text-dark-500">lien commercial avec un fabricant</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technologies maîtrisées — Logos partenaires -->
  <section class="py-20 bg-dark-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark-900">Les technologies que nous maîtrisons</h2>
        <p class="mt-4 text-lg text-dark-500 max-w-2xl mx-auto">
          Indépendants de toute marque — experts de tous les systèmes du marché
        </p>
      </div>

      <!-- Desktop : grille statique -->
      <div class="hidden md:grid md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <a href="/comparateur" class="group flex items-center justify-center p-6 bg-white rounded-xl border border-dark-200 hover:shadow-lg hover:border-primary-300 transition-all" title="Siemens — Technologie maîtrisée par NeoGTB">
          <img src="/images/logos/partenaires/logo-siemens.svg" alt="Siemens" class="h-10 grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300" />
        </a>
