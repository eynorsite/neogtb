  <script>
    function animateCounters() {
      const targets = { a: 84, b: 300, c: 10, d: 0 };
      const duration = 2000;
      const steps = 60;
      const interval = duration / steps;
      let step = 0;

      const timer = setInterval(() => {
        step++;
        const progress = step / steps;
        const eased = 1 - Math.pow(1 - progress, 3);

        document.querySelectorAll('[x-data]').forEach(el => {
          if (el.__x && el.__x.$data.counts) {
            el.__x.$data.counts.a = Math.round(targets.a * eased);
            el.__x.$data.counts.b = Math.round(targets.b * eased);
            el.__x.$data.counts.c = Math.round(targets.c * eased);
            el.__x.$data.counts.d = Math.round(targets.d * eased);
          }
        });

        if (step >= steps) clearInterval(timer);
      }, interval);
    }
  </script>

