---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Exercer vos droits RGPD" description="Exercez vos droits RGPD sur NeoGTB : accès, rectification, suppression, portabilité et opposition. Formulaire sécurisé, réponse sous 30 jours.">

  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-12">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-primary-100 text-primary-700 mb-4">
          RGPD — Vos droits
        </span>
        <h1 class="text-3xl md:text-4xl font-heading font-extrabold text-dark-900">Exercer vos droits RGPD</h1>
        <p class="mt-4 text-lg text-dark-500 max-w-xl mx-auto">
          Conformément au RGPD, vous disposez de droits sur vos données personnelles. Sélectionnez le type de demande ci-dessous.
        </p>
      </div>

      <div class="bg-white rounded-2xl border border-dark-200 shadow-sm p-6 md:p-8" x-data="rgpdForm()">

        <!-- Type de demande -->
        <div class="mb-8">
          <label class="block text-sm font-semibold text-dark-700 mb-3">Type de demande</label>
          <div class="space-y-2">
            <label class="flex items-start gap-3 p-3 rounded-lg border-2 cursor-pointer transition-all"
              :class="form.type === 'access' ? 'border-primary-500 bg-primary-50' : 'border-dark-200 hover:border-dark-300'">
              <input type="radio" name="type" value="access" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800">👁 Accéder à mes données</span>
                <span class="block text-xs text-dark-500">Droit d'accès — Obtenir une copie de toutes vos données</span>
              </div>
            </label>

            <label class="flex items-start gap-3 p-3 rounded-lg border-2 cursor-pointer transition-all"
              :class="form.type === 'rectification' ? 'border-primary-500 bg-primary-50' : 'border-dark-200 hover:border-dark-300'">
              <input type="radio" name="type" value="rectification" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800">✏️ Corriger mes données</span>
                <span class="block text-xs text-dark-500">Droit de rectification — Corriger des informations inexactes</span>
              </div>
            </label>

            <label class="flex items-start gap-3 p-3 rounded-lg border-2 cursor-pointer transition-all"
              :class="form.type === 'deletion' ? 'border-primary-500 bg-primary-50' : 'border-dark-200 hover:border-dark-300'">
              <input type="radio" name="type" value="deletion" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800">🗑️ Supprimer mes données</span>
                <span class="block text-xs text-dark-500">Droit à l'oubli — Effacer définitivement vos données</span>
              </div>
            </label>

            <label class="flex items-start gap-3 p-3 rounded-lg border-2 cursor-pointer transition-all"
              :class="form.type === 'portability' ? 'border-primary-500 bg-primary-50' : 'border-dark-200 hover:border-dark-300'">
              <input type="radio" name="type" value="portability" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800">📦 Exporter mes données</span>
                <span class="block text-xs text-dark-500">Droit à la portabilité — Recevoir vos données en format structuré</span>
              </div>
            </label>

            <label class="flex items-start gap-3 p-3 rounded-lg border-2 cursor-pointer transition-all"
              :class="form.type === 'opposition' ? 'border-primary-500 bg-primary-50' : 'border-dark-200 hover:border-dark-300'">
              <input type="radio" name="type" value="opposition" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800">🚫 M'opposer au traitement</span>
                <span class="block text-xs text-dark-500">Droit d'opposition — Cesser le traitement de vos données</span>
              </div>
            </label>
          </div>
        </div>

        <!-- Champs du formulaire -->
        <div class="space-y-4 mb-8">
          <div>
            <label class="block text-sm font-semibold text-dark-700 mb-1">Votre email</label>
            <input type="email" x-model="form.email" placeholder="votre@email.com" required
              class="w-full px-4 py-3 rounded-lg border border-dark-300 focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
          </div>
          <div>
            <label class="block text-sm font-semibold text-dark-700 mb-1">Votre nom</label>
            <input type="text" x-model="form.name" placeholder="Prénom Nom" required
              class="w-full px-4 py-3 rounded-lg border border-dark-300 focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
          </div>
          <div>
            <label class="block text-sm font-semibold text-dark-700 mb-1">Précisions <span class="text-dark-400 font-normal">(optionnel)</span></label>
            <textarea x-model="form.message" rows="4" placeholder="Décrivez votre demande si nécessaire..."
              class="w-full px-4 py-3 rounded-lg border border-dark-300 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 resize-y"></textarea>
          </div>
        </div>

        <!-- Info sécurité -->
        <div class="bg-primary-50 border border-primary-200 rounded-xl p-4 mb-6">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            <div class="text-sm">
              <p class="font-semibold text-primary-800">Vos données sont protégées</p>
              <p class="text-primary-700 mt-1">Votre demande sera chiffrée et traitée dans un délai légal de 30 jours. Seul le responsable RGPD de NeoGTB y aura accès.</p>
            </div>
          </div>
        </div>

        <!-- Bouton submit -->
        <button
          @click="submitForm()"
          :disabled="!form.type || !form.email || !form.name || submitted"
          class="w-full flex items-center justify-center gap-2 px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <template x-if="!submitted">
            <span class="flex items-center gap-2">
              Envoyer ma demande
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </template>
          <template x-if="submitted">
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Demande envoyée
            </span>
          </template>
        </button>

        <!-- Confirmation -->
        <div x-show="submitted" x-transition class="mt-6 bg-accent-50 border border-accent-200 rounded-xl p-4">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-accent-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div class="text-sm">
              <p class="font-semibold text-accent-800">Demande enregistrée</p>
              <p class="text-accent-700 mt-1">Nous avons bien reçu votre demande. Vous recevrez une confirmation par email et une réponse dans un délai maximum de 30 jours.</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Lien retour -->
      <div class="text-center mt-8">
        <a href="/politique-de-confidentialite" class="text-sm text-primary-600 hover:text-primary-700 font-medium">
          ← Consulter notre politique de confidentialité
        </a>
      </div>

    </div>
  </section>

</Layout>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('rgpdForm', () => ({
      form: {
        type: '',
        email: '',
        name: '',
        message: '',
      },
      submitted: false,

      async submitForm() {
        if (!this.form.type || !this.form.email || !this.form.name) return;
        // In production, this would POST to the Laravel backend
        // For now, simulate success
        this.submitted = true;
      },
    }));
  });
</script>
