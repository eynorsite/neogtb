---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Exercer vos droits RGPD" description="Exercez vos droits RGPD sur NeoGTB : accès, rectification, suppression, portabilité et opposition. Formulaire sécurisé, réponse sous 30 jours.">

  <section class="py-16 md:py-20">
    <div class="max-w-[680px] mx-auto px-4 sm:px-6">

      <div class="text-center mb-12">
        <p class="eyebrow">RGPD — Vos droits</p>
        <h1 class="font-heading font-medium text-dark-900" style="font-size:26px;letter-spacing:-0.4px;">Exercer vos droits RGPD</h1>
        <p class="mt-4 text-dark-500 max-w-xl mx-auto" style="font-size:14px;line-height:1.7;">
          Conformément au RGPD, vous disposez de droits sur vos données personnelles. Sélectionnez le type de demande ci-dessous.
        </p>
      </div>

      <div class="bg-white rounded-2xl p-6 md:p-8" style="border:0.5px solid rgba(0,0,0,0.08);" x-data="rgpdForm()">

        <!-- Type de demande -->
        <div class="mb-8">
          <label class="block text-sm font-medium text-dark-700 mb-3">Type de demande</label>
          <div class="space-y-2">
            <label class="flex items-start gap-3 p-3 rounded-lg cursor-pointer transition-all"
              style="border:0.5px solid rgba(0,0,0,0.08);"
              :style="form.type === 'access' ? 'border-color:var(--color-accent-500);background:var(--color-accent-50)' : ''"
              :class="form.type !== 'access' ? 'hover:bg-dark-50' : ''">
              <input type="radio" name="type" value="access" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800 text-sm">Accéder à mes données</span>
                <span class="block text-xs text-dark-400 mt-0.5">Droit d'accès — Obtenir une copie de toutes vos données</span>
              </div>
            </label>

            <label class="flex items-start gap-3 p-3 rounded-lg cursor-pointer transition-all"
              style="border:0.5px solid rgba(0,0,0,0.08);"
              :style="form.type === 'rectification' ? 'border-color:var(--color-accent-500);background:var(--color-accent-50)' : ''"
              :class="form.type !== 'rectification' ? 'hover:bg-dark-50' : ''">
              <input type="radio" name="type" value="rectification" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800 text-sm">Corriger mes données</span>
                <span class="block text-xs text-dark-400 mt-0.5">Droit de rectification — Corriger des informations inexactes</span>
              </div>
            </label>

            <label class="flex items-start gap-3 p-3 rounded-lg cursor-pointer transition-all"
              style="border:0.5px solid rgba(0,0,0,0.08);"
              :style="form.type === 'deletion' ? 'border-color:var(--color-accent-500);background:var(--color-accent-50)' : ''"
              :class="form.type !== 'deletion' ? 'hover:bg-dark-50' : ''">
              <input type="radio" name="type" value="deletion" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800 text-sm">Supprimer mes données</span>
                <span class="block text-xs text-dark-400 mt-0.5">Droit à l'oubli — Effacer définitivement vos données</span>
              </div>
            </label>

            <label class="flex items-start gap-3 p-3 rounded-lg cursor-pointer transition-all"
              style="border:0.5px solid rgba(0,0,0,0.08);"
              :style="form.type === 'portability' ? 'border-color:var(--color-accent-500);background:var(--color-accent-50)' : ''"
              :class="form.type !== 'portability' ? 'hover:bg-dark-50' : ''">
              <input type="radio" name="type" value="portability" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800 text-sm">Exporter mes données</span>
                <span class="block text-xs text-dark-400 mt-0.5">Droit à la portabilité — Recevoir vos données en format structuré</span>
              </div>
            </label>

            <label class="flex items-start gap-3 p-3 rounded-lg cursor-pointer transition-all"
              style="border:0.5px solid rgba(0,0,0,0.08);"
              :style="form.type === 'opposition' ? 'border-color:var(--color-accent-500);background:var(--color-accent-50)' : ''"
              :class="form.type !== 'opposition' ? 'hover:bg-dark-50' : ''">
              <input type="radio" name="type" value="opposition" x-model="form.type" class="mt-1">
              <div>
                <span class="font-medium text-dark-800 text-sm">M'opposer au traitement</span>
                <span class="block text-xs text-dark-400 mt-0.5">Droit d'opposition — Cesser le traitement de vos données</span>
              </div>
            </label>
          </div>
        </div>

        <!-- Champs du formulaire -->
        <div class="space-y-4 mb-8">
          <div>
            <label class="block text-sm font-medium text-dark-700 mb-1">Votre email</label>
            <input type="email" x-model="form.email" placeholder="votre@email.com" required
              class="w-full px-4 py-3 rounded-lg text-sm text-dark-700 focus:ring-2 focus:ring-accent-500 focus:outline-none"
              style="border:0.5px solid rgba(0,0,0,0.08);">
          </div>
          <div>
            <label class="block text-sm font-medium text-dark-700 mb-1">Votre nom</label>
            <input type="text" x-model="form.name" placeholder="Prénom Nom" required
              class="w-full px-4 py-3 rounded-lg text-sm text-dark-700 focus:ring-2 focus:ring-accent-500 focus:outline-none"
              style="border:0.5px solid rgba(0,0,0,0.08);">
          </div>
          <div>
            <label class="block text-sm font-medium text-dark-700 mb-1">Précisions <span class="text-dark-400 font-normal">(optionnel)</span></label>
            <textarea x-model="form.message" rows="4" placeholder="Décrivez votre demande si nécessaire..."
              class="w-full px-4 py-3 rounded-lg text-sm text-dark-700 focus:ring-2 focus:ring-accent-500 focus:outline-none resize-y"
              style="border:0.5px solid rgba(0,0,0,0.08);"></textarea>
          </div>
        </div>

        <!-- Info sécurité -->
        <div class="bg-accent-50 rounded-xl p-4 mb-6" style="border:0.5px solid rgba(0,0,0,0.08);">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-accent-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            <div class="text-sm" style="line-height:1.7;">
              <p class="font-medium text-accent-800">Vos données sont protégées</p>
              <p class="text-accent-700 mt-1">Votre demande sera chiffrée et traitée dans un délai légal de 30 jours. Seul le responsable RGPD de NeoGTB y aura accès.</p>
            </div>
          </div>
        </div>

        <!-- Bouton submit -->
        <button
          @click="submitForm()"
          :disabled="!form.type || !form.email || !form.name || submitted"
          class="w-full flex items-center justify-center gap-2 px-6 py-3 bg-accent-500 text-white font-medium rounded-lg hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
          style="font-size:13px;">
          <template x-if="!submitted">
            <span class="flex items-center gap-2">
              Envoyer ma demande
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </template>
          <template x-if="submitted">
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Demande envoyée
            </span>
          </template>
        </button>

        <!-- Confirmation -->
        <div x-show="submitted" x-transition class="mt-6 bg-accent-50 rounded-xl p-4" style="border:0.5px solid rgba(0,0,0,0.08);">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-accent-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div class="text-sm" style="line-height:1.7;">
              <p class="font-medium text-accent-800">Demande enregistrée</p>
              <p class="text-accent-700 mt-1">Nous avons bien reçu votre demande. Vous recevrez une confirmation par email et une réponse dans un délai maximum de 30 jours.</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Lien retour -->
      <div class="text-center mt-8">
        <a href="/politique-de-confidentialite" class="text-sm text-accent-600 hover:text-accent-700 font-medium">
          ← Consulter notre politique de confidentialité
        </a>
      </div>

    </div>
  </section>

</Layout>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('rgpdForm', () => ({
      form: {
        type: '',
        email: '',
        name: '',
        message: '',
      },
      submitted: false,

      async submitForm() {
        if (!this.form.type || !this.form.email || !this.form.name) return;
        // In production, this would POST to the Laravel backend
        // For now, simulate success
        this.submitted = true;
      },
    }));
  });
</script>
