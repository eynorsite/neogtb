---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inscription confirmée" description="Votre inscription à la veille GTB mensuelle NeoGTB est confirmée." noindex={true}>
  <section style="padding: 120px 0; text-align: center;">
    <div class="max-w-[600px] mx-auto px-6">
      <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--color-accent-50); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
        <svg width="32" height="32" fill="none" stroke="var(--color-accent-600)" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 style="font-size: 28px; font-weight: 500; color: var(--color-dark-900); letter-spacing: -0.02em; margin-bottom: 12px;">Inscription confirmée</h1>
      <p style="font-size: 16px; color: var(--color-dark-500); line-height: 1.7; margin-bottom: 32px;">
        Vous recevrez la veille GTB mensuelle NeoGTB dans votre boîte mail. 1 email par mois, désabonnement en 1 clic.
      </p>
      <a href="/" class="btn-primary">
        Retour à l'accueil
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Layout>
