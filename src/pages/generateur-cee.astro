---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Générateur de dossier CEE" description="Estimez vos Certificats d'Économies d'Énergie (CEE) en 3 minutes. Outil gratuit et indépendant — aucun lien commercial avec les obligés ou délégataires.">

  <!-- Hero -->
  <section class="bg-white py-16 border-b" style="border-bottom: 0.5px solid rgba(0,0,0,0.08);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="eyebrow inline-flex items-center px-3 py-1 rounded-full text-xs font-medium tracking-wide uppercase text-primary-600 bg-primary-50 mb-4" style="border: 0.5px solid rgba(0,0,0,0.08);">
        Outil indépendant
      </span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-medium text-dark-900">
        Générateur de dossier CEE
      </h1>
      <p class="mt-4 text-lg text-dark-500 max-w-2xl mx-auto">
        Estimez vos Certificats d'Économies d'Énergie en 3 minutes. Calcul basé sur les fiches standardisées (BAT-TH-116, BAT-TH-145, BAT-EQ-127...) — résultat objectif, sans engagement ni lien commercial.
      </p>
    </div>
  </section>

  <!-- Stepper + Formulaire -->
  <section class="py-12 md:py-20 bg-white min-h-[600px]"
    x-data="ceeGenerator()"
    x-cloak>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Barre de progression -->
      <div class="mb-10">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-normal text-dark-500" x-text="`Étape ${step} / 3`"></span>
          <span class="text-sm font-normal text-dark-500" x-text="`${Math.round((step / 3) * 100)}%`"></span>
        </div>
        <div class="w-full bg-dark-100 rounded-full h-1">
          <div class="bg-primary-600 h-1 rounded-full transition-all" style="transition-duration: 0.15s; transition-timing-function: ease;" :style="`width: ${(step / 3) * 100}%`"></div>
        </div>
      </div>

      <!-- Stepper visuel -->
      <div class="flex items-center justify-center gap-2 sm:gap-4 mb-10">
        <template x-for="(label, i) in ['Votre bâtiment', 'Vos équipements', 'Résultats']" :key="i">
          <div class="flex items-center gap-2 sm:gap-4">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium transition-colors"
                style="transition-duration: 0.15s; border: 0.5px solid rgba(0,0,0,0.08);"
                :class="step > i + 1 ? 'bg-accent-500 text-white' : step === i + 1 ? 'bg-primary-600 text-white' : 'bg-white text-dark-400'">
                <span x-show="step <= i + 1" x-text="i + 1"></span>
                <svg x-show="step > i + 1" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-xs sm:text-sm font-normal hidden sm:inline"
                :class="step === i + 1 ? 'text-dark-900' : 'text-dark-400'"
                x-text="label"></span>
            </div>
            <div x-show="i < 2" class="w-8 sm:w-16 h-px bg-dark-200"></div>
          </div>
        </template>
      </div>

      <!-- ÉTAPE 1 : Votre bâtiment -->
      <div x-show="step === 1" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-x-8" x-transition:enter-end="opacity-100 translate-x-0">
        <div class="bg-white rounded-2xl p-6 md:p-8" style="border: 0.5px solid rgba(0,0,0,0.08);">
          <h2 class="text-xl font-heading font-medium text-dark-900 mb-6">Type de bâtiment</h2>

          <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
            <template x-for="type in buildingTypes" :key="type.id">
              <button
                @click="form.buildingType = type.id"
                class="flex flex-col items-center gap-2 p-4 rounded-xl text-center transition-colors"
                style="border: 0.5px solid rgba(0,0,0,0.08); transition-duration: 0.15s;"
                :class="form.buildingType === type.id ? 'bg-primary-50 text-primary-700' : 'text-dark-600 hover:bg-dark-50'">
                <span class="text-2xl" x-text="type.icon"></span>
                <span class="text-sm font-medium" x-text="type.label"></span>
              </button>
            </template>
          </div>

          <div class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-dark-700 mb-2">Surface totale (m²)</label>
              <div class="relative">
                <input type="number" x-model.number="form.surface" min="100" max="100000" placeholder="Ex: 3000"
                  class="w-full px-4 py-3 rounded-lg transition-colors"
                  style="border: 0.5px solid rgba(0,0,0,0.08); border-radius: 8px; transition-duration: 0.15s;"
                  :class="errors.surface ? 'border-red-400 ring-1 ring-red-400' : 'focus:border-primary-500 focus:ring-3 focus:ring-primary-50'">
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-dark-400 text-sm">m²</span>
              </div>
              <p x-show="errors.surface" x-text="errors.surface" class="mt-1 text-sm text-red-500"></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-dark-700 mb-2">Zone climatique</label>
              <div class="grid grid-cols-3 gap-3">
                <template x-for="zone in ['H1', 'H2', 'H3']" :key="zone">
                  <button
                    @click="form.climateZone = zone"
                    class="py-3 px-4 rounded-lg text-center font-medium text-sm transition-colors"
                    style="border: 0.5px solid rgba(0,0,0,0.08); transition-duration: 0.15s;"
                    :class="form.climateZone === zone ? 'bg-primary-50 text-primary-700' : 'text-dark-600 hover:bg-dark-50'">
                    <span x-text="zone"></span>
                    <span class="block text-xs font-normal mt-1 text-dark-400"
                      x-text="zone === 'H1' ? 'Nord & Est' : zone === 'H2' ? 'Ouest & Centre' : 'Méditerranée'"></span>
                  </button>
                </template>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-dark-700 mb-2">Année de construction</label>
              <select x-model="form.buildingAge"
                class="w-full px-4 py-3 focus:border-primary-500 focus:ring-3 focus:ring-primary-50"
                style="border: 0.5px solid rgba(0,0,0,0.08); border-radius: 8px; transition-duration: 0.15s;">
                <option value="">Sélectionnez</option>
                <option value="before1975">Avant 1975</option>
                <option value="1975-2000">1975 - 2000</option>
                <option value="2000-2012">2000 - 2012</option>
                <option value="after2012">Après 2012 (RT2012/RE2020)</option>
              </select>
            </div>
          </div>

          <div class="flex justify-end mt-8">
            <button @click="validateStep1()" class="btn-primary inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors" style="transition-duration: 0.15s;">
              Suivant
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- ÉTAPE 2 : Vos équipements -->
      <div x-show="step === 2" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-x-8" x-transition:enter-end="opacity-100 translate-x-0">
        <div class="bg-white rounded-2xl p-6 md:p-8" style="border: 0.5px solid rgba(0,0,0,0.08);">
          <h2 class="text-xl font-heading font-medium text-dark-900 mb-2">Sélectionnez vos équipements</h2>
          <p class="text-sm text-dark-500 mb-6">Cochez les systèmes concernés par votre projet de rénovation ou d'optimisation énergétique. Chaque équipement correspond à une fiche CEE standardisée (BAT-TH ou BAT-EQ) définissant les critères d'éligibilité et le mode de calcul des économies.</p>

          <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
            <template x-for="equip in equipments" :key="equip.id">
              <button
                @click="toggleEquipment(equip.id)"
                class="flex items-center gap-3 p-4 rounded-xl transition-colors text-left"
                style="border: 0.5px solid rgba(0,0,0,0.08); transition-duration: 0.15s;"
                :class="form.selectedEquipments.includes(equip.id) ? 'bg-primary-50' : 'hover:bg-dark-50'">
                <div class="w-5 h-5 rounded flex items-center justify-center flex-shrink-0 transition-colors"
                  style="border: 0.5px solid rgba(0,0,0,0.08); transition-duration: 0.15s;"
                  :class="form.selectedEquipments.includes(equip.id) ? 'bg-primary-600 border-primary-600' : ''">
                  <svg x-show="form.selectedEquipments.includes(equip.id)" class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <span class="text-lg" x-text="equip.icon"></span>
                  <span class="text-sm font-medium block" :class="form.selectedEquipments.includes(equip.id) ? 'text-primary-700' : 'text-dark-600'" x-text="equip.label"></span>
                </div>
              </button>
            </template>
          </div>

          <p x-show="errors.equipments" x-text="errors.equipments" class="mb-4 text-sm text-red-500"></p>

          <!-- Champs dynamiques par équipement sélectionné -->
          <div class="space-y-6">
            <template x-for="eqId in form.selectedEquipments" :key="eqId">
              <div class="p-4 bg-dark-50 rounded-xl" style="border: 0.5px solid rgba(0,0,0,0.08);">
                <h3 class="font-medium text-dark-800 mb-3 flex items-center gap-2">
                  <span x-text="getEquipment(eqId).icon"></span>
                  <span x-text="getEquipment(eqId).label"></span>
                  <span class="text-xs font-normal text-dark-400 ml-auto" x-text="'Fiche ' + getEquipment(eqId).fiche"></span>
                </h3>
                <div class="grid sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-xs font-medium text-dark-500 mb-1">État actuel</label>
                    <select x-model="form.equipmentDetails[eqId].currentState"
                      class="w-full px-3 py-2 text-sm focus:border-primary-500 focus:ring-3 focus:ring-primary-50"
                      style="border: 0.5px solid rgba(0,0,0,0.08); border-radius: 8px;">
                      <option value="old">Ancien (> 15 ans)</option>
                      <option value="standard">Standard (5-15 ans)</option>
                      <option value="recent">Récent (< 5 ans)</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-dark-500 mb-1">Action prévue</label>
                    <select x-model="form.equipmentDetails[eqId].action"
                      class="w-full px-3 py-2 text-sm focus:border-primary-500 focus:ring-3 focus:ring-primary-50"
                      style="border: 0.5px solid rgba(0,0,0,0.08); border-radius: 8px;">
                      <option value="replace">Remplacement complet</option>
                      <option value="optimize">Optimisation / régulation</option>
                      <option value="gtb">Ajout pilotage GTB (conforme BAT-TH-116)</option>
                    </select>
                  </div>
                </div>
              </div>
            </template>
          </div>

          <div class="flex justify-between mt-8">
            <button @click="step = 1" class="inline-flex items-center gap-2 px-6 py-3 text-dark-600 font-medium rounded-lg hover:bg-dark-50 transition-colors" style="transition-duration: 0.15s;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Précédent
            </button>
            <button @click="validateStep2()" class="btn-primary inline-flex items-center gap-2 px-6 py-3 bg-accent-500 text-white font-medium rounded-lg hover:bg-accent-600 transition-colors" style="transition-duration: 0.15s;">
              Calculer mes CEE
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- ÉTAPE 3 : Résultats -->
      <div x-show="step === 3" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-x-8" x-transition:enter-end="opacity-100 translate-x-0">

        <!-- Titre résultats -->
        <div class="text-center mb-8">
          <h2 class="text-2xl md:text-3xl font-heading font-medium text-dark-900">Votre estimation CEE</h2>
          <p class="text-dark-500 mt-1">Basée sur les fiches standardisées et les paramètres que vous avez renseignés</p>
        </div>

        <!-- Cartes résultats principales -->
        <div class="grid md:grid-cols-2 gap-4 mb-6">
          <div class="bg-primary-600 rounded-2xl p-6 text-white text-center">
            <p class="text-sm font-medium text-primary-200 uppercase tracking-wide">Volume CEE estimé</p>
            <p class="text-4xl md:text-5xl font-heading font-medium mt-2" x-text="formatNumber(results.totalGwh) + ' GWh'"></p>
            <p class="text-sm text-primary-300 mt-1">cumac</p>
          </div>
          <div class="bg-accent-500 rounded-2xl p-6 text-white text-center">
            <p class="text-sm font-medium text-accent-100 uppercase tracking-wide">Valeur financière estimée</p>
            <p class="text-4xl md:text-5xl font-heading font-medium mt-2" x-text="formatCurrency(results.totalValue)"></p>
            <p class="text-sm text-accent-100 mt-1" x-text="`Fourchette : ${formatCurrency(results.lowValue)} — ${formatCurrency(results.highValue)}`"></p>
          </div>
        </div>

        <!-- Détail par opération -->
        <div class="bg-white rounded-2xl p-6 md:p-8 mb-6" style="border: 0.5px solid rgba(0,0,0,0.08);">
          <h3 class="text-lg font-heading font-medium text-dark-900 mb-4">Détail par opération</h3>
          <div class="space-y-3">
            <template x-for="detail in results.details" :key="detail.id">
              <div class="flex items-center justify-between p-4 bg-dark-50 rounded-xl" style="border: 0.5px solid rgba(0,0,0,0.08);">
                <div class="flex items-center gap-3">
                  <span class="text-xl" x-text="detail.icon"></span>
                  <div>
                    <p class="font-medium text-dark-800 text-sm" x-text="detail.label"></p>
                    <p class="text-xs text-dark-400" x-text="detail.fiche"></p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="font-medium text-dark-900 text-sm" x-text="formatNumber(detail.gwh) + ' GWh'"></p>
                  <p class="text-xs text-accent-600 font-medium" x-text="formatCurrency(detail.value)"></p>
                </div>
              </div>
            </template>
          </div>
        </div>

        <!-- Avertissement -->
        <div class="callout rounded-xl p-4 mb-6" style="border: 0.5px solid rgba(0,0,0,0.08); background-color: #fffbeb;">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            <div>
              <p class="font-medium text-amber-800 text-sm">Estimation indicative</p>
              <p class="text-sm text-amber-700 mt-1">Cette estimation est fournie à titre indicatif par un outil indépendant. Les volumes CEE réels dépendent de la fiche d'opération standardisée applicable (ex. BAT-TH-116 pour la GTB), du respect des critères d'éligibilité et d'un audit certifié par un bureau de contrôle. NeoGTB ne perçoit aucune commission sur les CEE.</p>
            </div>
          </div>
        </div>

        <!-- Paramètres utilisés -->
        <div class="bg-white rounded-2xl p-6 mb-6" style="border: 0.5px solid rgba(0,0,0,0.08);">
          <h3 class="text-lg font-heading font-medium text-dark-900 mb-4">Paramètres de votre estimation</h3>
          <div class="grid sm:grid-cols-2 gap-4 text-sm">
            <div class="flex justify-between py-2" style="border-bottom: 0.5px solid rgba(0,0,0,0.08);">
              <span class="text-dark-500">Type de bâtiment</span>
              <span class="font-medium text-dark-800" x-text="getBuildingTypeLabel()"></span>
            </div>
            <div class="flex justify-between py-2" style="border-bottom: 0.5px solid rgba(0,0,0,0.08);">
              <span class="text-dark-500">Surface</span>
              <span class="font-medium text-dark-800" x-text="formatNumber(form.surface) + ' m²'"></span>
            </div>
            <div class="flex justify-between py-2" style="border-bottom: 0.5px solid rgba(0,0,0,0.08);">
              <span class="text-dark-500">Zone climatique</span>
              <span class="font-medium text-dark-800" x-text="form.climateZone"></span>
            </div>
            <div class="flex justify-between py-2" style="border-bottom: 0.5px solid rgba(0,0,0,0.08);">
              <span class="text-dark-500">Année de construction</span>
              <span class="font-medium text-dark-800" x-text="getBuildingAgeLabel()"></span>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="bg-white rounded-2xl p-6" style="border: 0.5px solid rgba(0,0,0,0.08);">
          <div class="grid sm:grid-cols-2 gap-3">
            <button @click="downloadPDF()" class="btn-primary flex items-center justify-center gap-2 px-5 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors text-sm" style="transition-duration: 0.15s;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              Télécharger le rapport PDF
            </button>
            <a href="/contact" class="btn-primary flex items-center justify-center gap-2 px-5 py-3 bg-accent-500 text-white font-medium rounded-lg hover:bg-accent-600 transition-colors text-sm" style="transition-duration: 0.15s;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Être contacté par un expert
            </a>
            <button @click="emailResults()" class="flex items-center justify-center gap-2 px-5 py-3 bg-dark-50 text-dark-700 font-medium rounded-lg hover:bg-dark-100 transition-colors text-sm" style="border: 0.5px solid rgba(0,0,0,0.08); transition-duration: 0.15s;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              Recevoir par email
            </button>
            <button @click="step = 1; resetResults()" class="flex items-center justify-center gap-2 px-5 py-3 bg-dark-50 text-dark-700 font-medium rounded-lg hover:bg-dark-100 transition-colors text-sm" style="border: 0.5px solid rgba(0,0,0,0.08); transition-duration: 0.15s;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Nouvelle simulation
            </button>
          </div>
        </div>

        <!-- Modal email -->
        <div x-show="showEmailModal" x-transition.opacity class="fixed inset-0 z-[70] flex items-center justify-center p-4 bg-dark-900/50 backdrop-blur-sm">
          <div @click.outside="showEmailModal = false" class="bg-white rounded-2xl max-w-md w-full p-6" style="border: 0.5px solid rgba(0,0,0,0.08);">
            <h3 class="font-heading font-medium text-dark-900 mb-4">Recevoir mon estimation par email</h3>
            <input type="email" x-model="emailAddress" placeholder="votre@email.com"
              class="w-full px-4 py-3 focus:border-primary-500 focus:ring-3 focus:ring-primary-50 mb-4"
              style="border: 0.5px solid rgba(0,0,0,0.08); border-radius: 8px;">
            <p class="text-xs text-dark-400 mb-4">Votre email ne sera utilisé que pour cet envoi. Aucun démarchage.</p>
            <div class="flex gap-3">
              <button @click="showEmailModal = false" class="flex-1 px-4 py-2.5 text-sm font-medium text-dark-600 bg-dark-50 rounded-lg hover:bg-dark-100 transition-colors" style="border: 0.5px solid rgba(0,0,0,0.08); transition-duration: 0.15s;">Annuler</button>
              <button @click="sendEmail()" class="btn-primary flex-1 px-4 py-2.5 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors" style="transition-duration: 0.15s;">Envoyer</button>
            </div>
            <p x-show="emailSent" class="mt-3 text-sm text-accent-600 font-medium text-center">Email envoyé (simulation — fonctionnalité backend requise)</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Badge indépendance -->
  <section class="py-12 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div class="callout inline-flex items-center gap-3 px-6 py-3 bg-primary-50 rounded-full" style="border: 0.5px solid rgba(0,0,0,0.08);">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <span class="text-sm font-medium text-primary-700">Outil indépendant — NeoGTB ne perçoit aucune commission sur les CEE générés</span>
      </div>
    </div>
  </section>

<style>
  [x-cloak] { display: none !important; }
</style>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('ceeGenerator', () => ({
      step: 1,
      errors: {},
      showEmailModal: false,
      emailAddress: '',
      emailSent: false,

      buildingTypes: [
        { id: 'office', label: 'Bureaux', icon: '🏢' },
        { id: 'industry', label: 'Industrie', icon: '🏭' },
        { id: 'health', label: 'Santé', icon: '🏥' },
        { id: 'education', label: 'Enseignement', icon: '🏫' },
        { id: 'hotel', label: 'Hôtellerie', icon: '🏨' },
        { id: 'commercial', label: 'Commerce', icon: '🛒' },
      ],

      equipments: [
        { id: 'heating', label: 'Chauffage', icon: '🌡️', fiche: 'BAT-TH-116', baseCee: 0.042 },
        { id: 'cooling', label: 'Climatisation', icon: '❄️', fiche: 'BAT-TH-145', baseCee: 0.028 },
        { id: 'lighting', label: 'Éclairage', icon: '💡', fiche: 'BAT-EQ-127', baseCee: 0.018 },
        { id: 'ventilation', label: 'Ventilation', icon: '🌀', fiche: 'BAT-TH-142', baseCee: 0.022 },
        { id: 'hotwater', label: 'Eau chaude', icon: '🚿', fiche: 'BAT-TH-148', baseCee: 0.015 },
        { id: 'motors', label: 'Motorisation', icon: '⚙️', fiche: 'BAT-EQ-133', baseCee: 0.012 },
      ],

      form: {
        buildingType: '',
        surface: null,
        climateZone: '',
        buildingAge: '',
        selectedEquipments: [],
        equipmentDetails: {},
      },

      results: {
        totalGwh: 0,
        totalValue: 0,
        lowValue: 0,
        highValue: 0,
        details: [],
      },

      // Coefficients
      zoneCoeff: { 'H1': 1.3, 'H2': 1.0, 'H3': 0.7 },
      ageCoeff: { 'before1975': 1.5, '1975-2000': 1.2, '2000-2012': 1.0, 'after2012': 0.6 },
      typeCoeff: { 'office': 1.0, 'industry': 1.3, 'health': 1.4, 'education': 1.1, 'hotel': 1.2, 'commercial': 0.9 },
      actionCoeff: { 'replace': 1.0, 'optimize': 0.6, 'gtb': 0.45 },
      stateCoeff: { 'old': 1.3, 'standard': 1.0, 'recent': 0.5 },

      toggleEquipment(id) {
        const idx = this.form.selectedEquipments.indexOf(id);
        if (idx > -1) {
          this.form.selectedEquipments.splice(idx, 1);
          delete this.form.equipmentDetails[id];
        } else {
          this.form.selectedEquipments.push(id);
          this.form.equipmentDetails[id] = { currentState: 'old', action: 'replace' };
        }
      },

      getEquipment(id) {
        return this.equipments.find(e => e.id === id) || {};
      },

      getBuildingTypeLabel() {
        const t = this.buildingTypes.find(b => b.id === this.form.buildingType);
        return t ? t.label : '';
      },

      getBuildingAgeLabel() {
        const labels = { 'before1975': 'Avant 1975', '1975-2000': '1975-2000', '2000-2012': '2000-2012', 'after2012': 'Après 2012' };
        return labels[this.form.buildingAge] || '';
      },

      formatNumber(n) {
        if (n === null || n === undefined) return '0';
        return new Intl.NumberFormat('fr-FR').format(Math.round(n * 100) / 100);
      },

      formatCurrency(n) {
        return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);
      },

      validateStep1() {
        this.errors = {};
        if (!this.form.buildingType) this.errors.buildingType = 'Sélectionnez un type de bâtiment';
        if (!this.form.surface || this.form.surface < 100) this.errors.surface = 'Surface minimale : 100 m²';
        if (!this.form.climateZone) this.errors.climateZone = 'Sélectionnez une zone climatique';
        if (!this.form.buildingAge) this.errors.buildingAge = 'Sélectionnez une période';
        if (Object.keys(this.errors).length === 0) this.step = 2;
      },

      validateStep2() {
        this.errors = {};
        if (this.form.selectedEquipments.length === 0) {
          this.errors.equipments = 'Sélectionnez au moins un équipement';
          return;
        }
        this.calculateResults();
        this.step = 3;
      },

      calculateResults() {
        const surface = this.form.surface;
        const zCoeff = this.zoneCoeff[this.form.climateZone] || 1;
        const aCoeff = this.ageCoeff[this.form.buildingAge] || 1;
        const tCoeff = this.typeCoeff[this.form.buildingType] || 1;
        const pricePerGwh = 8.5; // €/MWh cumac approximatif 2026

        let details = [];
        let totalGwh = 0;

        for (const eqId of this.form.selectedEquipments) {
          const equip = this.getEquipment(eqId);
          const eqDetails = this.form.equipmentDetails[eqId] || {};
          const actCoeff = this.actionCoeff[eqDetails.action] || 1;
          const stCoeff = this.stateCoeff[eqDetails.currentState] || 1;

          // Formule : baseCee * surface * zoneCoeff * ageCoeff * typeCoeff * actionCoeff * stateCoeff / 1000 (en GWh)
          const gwh = equip.baseCee * surface * zCoeff * aCoeff * tCoeff * actCoeff * stCoeff / 1000;
          const value = gwh * pricePerGwh * 1000; // valeur en euros

          totalGwh += gwh;
          details.push({
            id: eqId,
            label: equip.label,
            icon: equip.icon,
            fiche: `Fiche ${equip.fiche}`,
            gwh: gwh,
            value: value,
          });
        }

        this.results = {
          totalGwh: totalGwh,
          totalValue: totalGwh * pricePerGwh * 1000,
          lowValue: totalGwh * pricePerGwh * 1000 * 0.75,
          highValue: totalGwh * pricePerGwh * 1000 * 1.25,
          details: details,
        };
      },

      async downloadPDF() {
        const { jsPDF } = await import('jspdf');
        const doc = new jsPDF();
        const margin = 20;
        let y = margin;

        // Header
        doc.setFontSize(22);
        doc.setTextColor(37, 99, 235); // primary-600
        doc.text('NeoGTB', margin, y);
        doc.setFontSize(10);
        doc.setTextColor(100, 116, 139);
        doc.text('Tiers de confiance independant de la GTB', margin + 45, y);
        y += 15;

        doc.setDrawColor(37, 99, 235);
        doc.setLineWidth(0.5);
        doc.line(margin, y, 190, y);
        y += 15;

        // Title
        doc.setFontSize(18);
        doc.setTextColor(15, 23, 42);
        doc.text('Estimation Certificats d\'Economies d\'Energie', margin, y);
        y += 10;

        doc.setFontSize(10);
        doc.setTextColor(100, 116, 139);
        doc.text('Date : ' + new Date().toLocaleDateString('fr-FR'), margin, y);
        y += 15;

        // Summary boxes
        doc.setFillColor(37, 99, 235);
        doc.roundedRect(margin, y, 80, 30, 3, 3, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(9);
        doc.text('VOLUME CEE ESTIME', margin + 5, y + 10);
        doc.setFontSize(16);
        doc.text(this.formatNumber(this.results.totalGwh) + ' GWh cumac', margin + 5, y + 22);

        doc.setFillColor(34, 197, 94);
        doc.roundedRect(105, y, 80, 30, 3, 3, 'F');
        doc.setFontSize(9);
        doc.text('VALEUR FINANCIERE ESTIMEE', 110, y + 10);
        doc.setFontSize(16);
        doc.text(this.formatCurrency(this.results.totalValue), 110, y + 22);
        y += 40;

        // Fourchette
        doc.setTextColor(100, 116, 139);
        doc.setFontSize(9);
        doc.text('Fourchette : ' + this.formatCurrency(this.results.lowValue) + ' - ' + this.formatCurrency(this.results.highValue), margin, y);
        y += 15;

        // Parameters
        doc.setTextColor(15, 23, 42);
        doc.setFontSize(13);
        doc.text('Parametres de l\'estimation', margin, y);
        y += 8;

        doc.setFontSize(10);
        doc.setTextColor(71, 85, 105);
        const params = [
          ['Type de batiment', this.getBuildingTypeLabel()],
          ['Surface', this.formatNumber(this.form.surface) + ' m2'],
          ['Zone climatique', this.form.climateZone],
          ['Annee de construction', this.getBuildingAgeLabel()],
        ];
        for (const [label, value] of params) {
          doc.text(label + ' : ', margin, y);
          doc.setTextColor(15, 23, 42);
          doc.text(value, margin + 60, y);
          doc.setTextColor(71, 85, 105);
          y += 7;
        }
        y += 10;

        // Detail par opération
        doc.setTextColor(15, 23, 42);
        doc.setFontSize(13);
        doc.text('Detail par operation', margin, y);
        y += 10;

        doc.setFontSize(9);
        doc.setTextColor(100, 116, 139);
        doc.text('EQUIPEMENT', margin, y);
        doc.text('FICHE CEE', 90, y);
        doc.text('GWh', 135, y);
        doc.text('VALEUR', 160, y);
        y += 3;
        doc.line(margin, y, 190, y);
        y += 7;

        doc.setTextColor(15, 23, 42);
        doc.setFontSize(10);
        for (const detail of this.results.details) {
          doc.text(detail.label, margin, y);
          doc.setTextColor(100, 116, 139);
          doc.text(detail.fiche, 90, y);
          doc.setTextColor(15, 23, 42);
          doc.text(this.formatNumber(detail.gwh) + ' GWh', 135, y);
          doc.setTextColor(34, 197, 94);
          doc.text(this.formatCurrency(detail.value), 160, y);
          doc.setTextColor(15, 23, 42);
          y += 8;
        }
        y += 10;

        // Disclaimer
        doc.setFillColor(255, 251, 235);
        doc.roundedRect(margin, y, 170, 25, 3, 3, 'F');
        doc.setFontSize(8);
        doc.setTextColor(146, 64, 14);
        doc.text('ESTIMATION INDICATIVE', margin + 5, y + 8);
        doc.setFontSize(7);
        doc.text('Cette estimation est fournie a titre indicatif par un outil independant.', margin + 5, y + 14);
        doc.text('Un audit certifie est requis pour un dossier CEE officiel. NeoGTB ne percoit aucune commission.', margin + 5, y + 19);
        y += 35;

        // Footer
        doc.setFontSize(8);
        doc.setTextColor(148, 163, 184);
        doc.text('NeoGTB - Tiers de confiance independant de la GTB en France | neogtb.fr', margin, 285);
        doc.text('Ce document ne constitue pas un engagement contractuel.', margin, 290);

        doc.save('estimation-cee-neogtb.pdf');
      },

      emailResults() {
        this.showEmailModal = true;
        this.emailSent = false;
      },

      sendEmail() {
        if (!this.emailAddress || !this.emailAddress.includes('@')) return;
        // Placeholder — nécessite un backend pour l'envoi réel
        this.emailSent = true;
        setTimeout(() => { this.showEmailModal = false; this.emailSent = false; }, 2000);
      },

      resetResults() {
        this.results = { totalGwh: 0, totalValue: 0, lowValue: 0, highValue: 0, details: [] };
        this.errors = {};
      },
    }));
  });
</script>

</Layout>
