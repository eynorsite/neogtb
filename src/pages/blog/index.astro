---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const featured = posts.filter(p => p.data.featured);
const allPosts = posts;
---

<Layout title="Blog - Articles techniques GTB/GTC" description="Articles techniques, guides pratiques et actualités sur la Gestion Technique du Bâtiment (GTB) et la Gestion Technique Centralisée (GTC).">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-900 via-primary-800 to-dark-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-extrabold">Blog <span class="text-accent-400">NeoGTB</span></h1>
      <p class="mt-4 text-lg text-dark-300 max-w-xl mx-auto">
        Articles techniques, guides pratiques et actualités sur la gestion technique du bâtiment.
      </p>
    </div>
  </section>

  <!-- Articles -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      {featured.length > 0 && (
        <div class="mb-16">
          <h2 class="text-2xl font-heading font-bold text-dark-900 mb-8">Articles à la une</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {featured.map((post) => (
              <a href={`/blog/${post.id}`} class="group block bg-white rounded-2xl border border-dark-200 overflow-hidden hover:shadow-xl transition-all duration-300">
                <div class="p-6">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="px-2 py-1 bg-primary-100 text-primary-700 text-xs font-semibold rounded-full">{post.data.category}</span>
                    <span class="text-xs text-dark-400">{new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                  </div>
                  <h3 class="text-lg font-heading font-bold text-dark-900 group-hover:text-primary-600 transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="mt-2 text-sm text-dark-500 line-clamp-3">{post.data.description}</p>
                  <div class="mt-4 flex flex-wrap gap-1">
                    {post.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="px-2 py-0.5 bg-dark-100 text-dark-500 text-xs rounded-full">{tag}</span>
                    ))}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <h2 class="text-2xl font-heading font-bold text-dark-900 mb-8">Tous les articles</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="group block bg-white rounded-2xl border border-dark-200 overflow-hidden hover:shadow-xl transition-all duration-300">
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2 py-1 bg-dark-100 text-dark-600 text-xs font-semibold rounded-full">{post.data.category}</span>
                <span class="text-xs text-dark-400">{new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              </div>
              <h3 class="text-lg font-heading font-bold text-dark-900 group-hover:text-primary-600 transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="mt-2 text-sm text-dark-500 line-clamp-3">{post.data.description}</p>
              <div class="mt-4 flex flex-wrap gap-1">
                {post.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="px-2 py-0.5 bg-dark-100 text-dark-500 text-xs rounded-full">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>
