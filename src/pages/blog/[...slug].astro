---
import Layout from '../../layouts/Layout.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Reading time estimate (~200 words/min for French)
const words = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(words / 200));

const formattedDate = new Date(post.data.date).toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": new Date(post.data.date).toISOString(),
  "dateModified": new Date(post.data.date).toISOString(),
  "author": { "@type": "Organization", "name": post.data.author || "NeoGTB", "url": "https://neogtb.fr" },
  "publisher": { "@type": "Organization", "name": "NeoGTB", "url": "https://neogtb.fr", "logo": { "@type": "ImageObject", "url": "https://neogtb.fr/images/logo-neogtb.webp" } },
  "mainEntityOfPage": `https://neogtb.fr/blog/${post.id}`,
  ...(post.data.image ? { image: `https://neogtb.fr${post.data.image}` } : {}),
};

const ogImage = post.data.image ? `https://neogtb.fr${post.data.image}` : "https://neogtb.fr/images/og-neogtb.png";
---

<Layout title={post.data.title} description={post.data.description} ogType="article" ogImage={ogImage} jsonLd={articleJsonLd} breadcrumbs={[{label: "Blog", href: "/blog"}, {label: post.data.title}]}>

  <article class="article-page">
    <div class="article-column">

      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/blog" class="breadcrumb-link">&larr; Perspectives</a>
        <span class="sep"></span>
        <span class="tag">{post.data.category}</span>
      </nav>

      <!-- Title -->
      <h1 class="article-title">{post.data.title}</h1>

      <!-- Byline -->
      <div class="byline">
        <span class="byline-author">{post.data.author}</span>
        <span class="byline-dot">&middot;</span>
        <time datetime={new Date(post.data.date).toISOString()}>{formattedDate}</time>
        <span class="byline-dot">&middot;</span>
        <span>{readingTime} min de lecture</span>
      </div>

      <!-- Separator -->
      <hr class="article-sep" />

      <!-- Lead -->
      {post.data.description && (
        <p class="article-lead">{post.data.description}</p>
      )}

      <!-- Content -->
      <div class="article-prose">
        <Content />
      </div>

      <!-- Tags -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="article-tags">
          {post.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}

      <!-- Back link -->
      <hr class="article-sep" />
      <a href="/blog" class="back-link">&larr; Retour aux Perspectives</a>

    </div>
  </article>

  <!-- ==================== CTA ==================== -->
  <section class="article-cta">
    <div class="article-cta-inner">
      <h2 class="article-cta-title">Un projet GTB à clarifier ?</h2>
      <p class="article-cta-text">Pré-diagnostic ISO 52120-1 gratuit en ligne, ou échange de 15 minutes pour cadrer votre besoin.</p>
      <div class="article-cta-buttons">
        <a href="/audit" class="btn-primary">
          Lancer le diagnostic
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
        <a href="/contact" class="article-cta-link">Me contacter &rarr;</a>
      </div>
    </div>
  </section>

  <RelatedPages links={[
    { href: "/audit", title: "Pré-diagnostic ISO 52120-1 en ligne", description: "Évaluez gratuitement la classe de performance GTB de votre bâtiment." },
    { href: "/generateur-cee", title: "Générateur de fiches CEE", description: "Estimez vos primes CEE pour un projet GTB en quelques clics." },
    { href: "/comparateur", title: "Comparateur de solutions GTB", description: "Comparez les protocoles et technologies GTB pour votre projet." },
  ]} />

</Layout>

<style>
  /* ── Page ── */
  .article-page {
    padding: 48px 20px 80px;
  }

  .article-column {
    max-width: 680px;
    margin: 0 auto;
  }

  /* ── Breadcrumb ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
  }

  .breadcrumb-link {
    font-size: 14px;
    font-weight: 400;
    color: var(--text-secondary, #5A5A6A);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb-link:hover {
    color: var(--accent, var(--color-accent-600, #0D9488));
  }

  /* ── Shared classes ── */
  .sep {
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-muted, #9A9AAA);
    flex-shrink: 0;
  }

  .tag {
    display: inline-block;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    color: var(--accent-dark, var(--color-accent-700, #0F766E));
    background: var(--accent-light, var(--color-accent-50, #F0FDFA));
    border-radius: 4px;
    line-height: 1.4;
  }

  /* ── Eyebrow (available for use) ── */
  .eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--text-muted, #9A9AAA);
  }

  /* ── Title ── */
  .article-title {
    font-size: 30px;
    font-weight: 500;
    letter-spacing: -0.5px;
    line-height: 1.3;
    color: var(--text-primary, #0F0F0F);
    margin: 0 0 20px;
  }

  /* ── Byline ── */
  .byline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-secondary, #5A5A6A);
  }

  .byline-author {
    font-weight: 500;
    color: var(--text-primary, #0F0F0F);
  }

  .byline-dot {
    color: var(--text-muted, #9A9AAA);
  }

  /* ── Separator ── */
  .article-sep {
    border: none;
    border-top: 0.5px solid rgba(0, 0, 0, 0.08);
    margin: 24px 0;
  }

  /* ── Lead paragraph ── */
  .article-lead {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.7;
    color: var(--text-secondary, #5A5A6A);
    margin: 0 0 32px;
  }

  /* ── Prose (rendered Markdown) ── */
  .article-prose {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--text-secondary, #5A5A6A);
  }

  .article-prose :global(h2) {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.3px;
    color: var(--text-primary, #0F0F0F);
    margin: 48px 0 16px;
    line-height: 1.2;
  }

  .article-prose :global(h3) {
    font-size: 18px;
    font-weight: 500;
    color: var(--text-primary, #0F0F0F);
    margin: 36px 0 12px;
    line-height: 1.3;
  }

  .article-prose :global(h4) {
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary, #0F0F0F);
    margin: 28px 0 8px;
  }

  .article-prose :global(p) {
    margin: 0 0 20px;
  }

  .article-prose :global(a) {
    color: var(--accent, var(--color-accent-600, #0D9488));
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(13, 148, 136, 0.3);
    font-weight: 400;
    transition: text-decoration-color 0.15s;
  }

  .article-prose :global(a:hover) {
    text-decoration-color: var(--accent, var(--color-accent-600, #0D9488));
  }

  .article-prose :global(strong) {
    font-weight: 500;
    color: var(--text-primary, #0F0F0F);
  }

  .article-prose :global(ul),
  .article-prose :global(ol) {
    margin: 0 0 20px;
    padding-left: 20px;
  }

  .article-prose :global(li) {
    margin-bottom: 8px;
  }

  .article-prose :global(blockquote) {
    margin: 32px 0;
    padding: 16px 24px;
    border-left: 2px solid var(--accent, var(--color-accent-600, #0D9488));
    background: none;
    font-size: 15px;
    font-weight: 400;
    color: var(--text-secondary, #5A5A6A);
    font-style: italic;
  }

  .article-prose :global(blockquote p) {
    margin: 0;
  }

  .article-prose :global(code) {
    font-size: 13px;
    padding: 2px 6px;
    background: var(--surface-alt, #F7F7F9);
    border: 0.5px solid rgba(0, 0, 0, 0.08);
    border-radius: 4px;
  }

  .article-prose :global(pre) {
    margin: 24px 0;
    padding: 20px 24px;
    background: var(--surface-alt, #F7F7F9);
    border: 0.5px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
  }

  .article-prose :global(pre code) {
    padding: 0;
    background: none;
    border: none;
    border-radius: 0;
  }

  .article-prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 32px 0;
    border: 0.5px solid rgba(0, 0, 0, 0.08);
  }

  .article-prose :global(hr) {
    border: none;
    border-top: 0.5px solid rgba(0, 0, 0, 0.08);
    margin: 40px 0;
  }

  .article-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 14px;
  }

  .article-prose :global(th) {
    font-weight: 500;
    text-align: left;
    padding: 10px 16px;
    border-bottom: 0.5px solid rgba(0, 0, 0, 0.08);
    color: var(--text-primary, #0F0F0F);
  }

  .article-prose :global(td) {
    padding: 10px 16px;
    border-bottom: 0.5px solid rgba(0, 0, 0, 0.08);
  }

  /* ── Tags bottom ── */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 0.5px solid rgba(0, 0, 0, 0.08);
  }

  /* ── Back link ── */
  .back-link {
    display: inline-block;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-secondary, #5A5A6A);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent, var(--color-accent-600, #0D9488));
  }

  /* ── CTA Section ── */
  .article-cta {
    padding: 64px 20px;
    background: #F0F2F5;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    text-align: center;
  }

  .article-cta-inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .article-cta-title {
    font-size: 26px;
    font-weight: 500;
    color: var(--text-primary, #0F0F0F);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 12px;
  }

  .article-cta-text {
    font-size: 15px;
    color: var(--text-secondary, #5A5A6A);
    line-height: 1.7;
    margin: 0 0 28px;
  }

  .article-cta-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .article-cta-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary, #5A5A6A);
    text-decoration: none;
    transition: color 0.15s;
  }

  .article-cta-link:hover {
    color: var(--accent, var(--color-accent-600, #0D9488));
  }
</style>
