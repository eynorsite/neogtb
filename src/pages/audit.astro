  /* ── Regulatory urgency ── */
  .diag-regulatory { display: flex; gap: 16px; align-items: flex-start; padding: 20px; border-radius: 12px; }
  .diag-regulatory-critical { background: #fef2f2; border: 1px solid #fecaca; }
