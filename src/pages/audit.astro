---
import Layout from '../layouts/Layout.astro';
import RelatedPages from '../components/RelatedPages.astro';
---

<Layout title="Audit GTB gratuit en ligne — Diagnostic EN 15232 en 5 min" description="Évaluez gratuitement le niveau GTB de votre bâtiment tertiaire selon la norme EN 15232. Diagnostic personnalisé avec recommandations et estimation des économies d'énergie CVC." breadcrumbs={[{label: "Outils"}, {label: "Audit GTB"}]}>

  <!-- Hero -->
  <section class="hero-lum">
    <div class="hero-lum-mesh"></div>
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <div class="hero-lum-grid"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <span class="eyebrow">Diagnostic gratuit</span>
      <h1 class="mt-5 text-4xl md:text-5xl font-heading font-medium" style="letter-spacing: -0.4px;">Diagnostic <span class="accent">GTB</span> de votre bâtiment</h1>
      <p class="mt-4 text-lg max-w-2xl mx-auto" style="font-weight: 400; color: var(--color-dark-500);">
        Évaluez en 8 questions la maturité de votre gestion technique selon le référentiel EN 15232 et les classes de performance A à D. Recevez un diagnostic et des recommandations personnalisées.
      </p>
    </div>
  </section>

  <!-- Audit Wizard -->
  <section class="pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <div x-data="auditWizard()">

        <!-- Progress Bar -->
        <div class="mb-8">
          <div class="flex justify-between text-sm text-dark-500 mb-2" style="font-weight: 400;">
            <span>Question <span x-text="currentStep"></span> / <span x-text="totalSteps"></span></span>
            <span x-text="Math.round((currentStep - 1) / totalSteps * 100) + '%'"></span>
          </div>
          <div class="w-full rounded-full h-1" style="background: rgba(0,0,0,0.06);">
            <div class="bg-accent-500 h-1 rounded-full" style="transition: width 0.15s ease;" :style="'width: ' + ((currentStep - 1) / totalSteps * 100) + '%'"></div>
          </div>
        </div>

        <!-- Questions -->
        <div x-show="!showResults" class="bg-white rounded-xl p-8" style="border: 0.5px solid rgba(0,0,0,0.08);">

          <!-- Question 1 -->
          <div x-show="currentStep === 1">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Quel type de bâtiment gérez-vous ? La classification EN 15232 varie selon l'usage.</h3>
            <div class="space-y-3">
              <template x-for="option in questions[0].options" :key="option.value">
                <label class="flex items-center gap-3 p-4 rounded-xl cursor-pointer" style="border: 0.5px solid rgba(0,0,0,0.08); transition: border-color 0.15s ease;" :style="answers[0] === option.value ? 'border-color: var(--color-accent-500); background: var(--color-accent-50);' : ''">
                  <input type="radio" name="q1" :value="option.value" x-model="answers[0]" class="text-accent-500" />
                  <span class="text-dark-700" style="font-weight: 400;" x-text="option.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Question 2 -->
          <div x-show="currentStep === 2">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Quelle est la surface de votre bâtiment ? Le décret BACS impose une GTB pour les bâtiments tertiaires de plus de 290 kW.</h3>
            <div class="space-y-3">
              <template x-for="option in questions[1].options" :key="option.value">
                <label class="flex items-center gap-3 p-4 rounded-xl cursor-pointer" style="border: 0.5px solid rgba(0,0,0,0.08); transition: border-color 0.15s ease;" :style="answers[1] === option.value ? 'border-color: var(--color-accent-500); background: var(--color-accent-50);' : ''">
                  <input type="radio" name="q2" :value="option.value" x-model="answers[1]" class="text-accent-500" />
                  <span class="text-dark-700" style="font-weight: 400;" x-text="option.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Question 3 -->
          <div x-show="currentStep === 3">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Disposez-vous d'un système de régulation CVC ? La régulation est un critère central de la norme EN 15232 pour le classement énergétique.</h3>
            <div class="space-y-3">
              <template x-for="option in questions[2].options" :key="option.value">
                <label class="flex items-center gap-3 p-4 rounded-xl cursor-pointer" style="border: 0.5px solid rgba(0,0,0,0.08); transition: border-color 0.15s ease;" :style="answers[2] === option.value ? 'border-color: var(--color-accent-500); background: var(--color-accent-50);' : ''">
                  <input type="radio" name="q3" :value="option.value" x-model="answers[2]" class="text-accent-500" />
                  <span class="text-dark-700" style="font-weight: 400;" x-text="option.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Question 4 -->
          <div x-show="currentStep === 4">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Comment est géré l'éclairage ? La norme EN 12464-1 définit les niveaux d'éclairement requis selon les usages.</h3>
            <div class="space-y-3">
              <template x-for="option in questions[3].options" :key="option.value">
                <label class="flex items-center gap-3 p-4 rounded-xl cursor-pointer" style="border: 0.5px solid rgba(0,0,0,0.08); transition: border-color 0.15s ease;" :style="answers[3] === option.value ? 'border-color: var(--color-accent-500); background: var(--color-accent-50);' : ''">
                  <input type="radio" name="q4" :value="option.value" x-model="answers[3]" class="text-accent-500" />
                  <span class="text-dark-700" style="font-weight: 400;" x-text="option.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Question 5 -->
          <div x-show="currentStep === 5">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Avez-vous un suivi des consommations énergétiques ? Le décret tertiaire exige une réduction progressive des consommations avec reporting sur OPERAT.</h3>
            <div class="space-y-3">
              <template x-for="option in questions[4].options" :key="option.value">
                <label class="flex items-center gap-3 p-4 rounded-xl cursor-pointer" style="border: 0.5px solid rgba(0,0,0,0.08); transition: border-color 0.15s ease;" :style="answers[4] === option.value ? 'border-color: var(--color-accent-500); background: var(--color-accent-50);' : ''">
                  <input type="radio" name="q5" :value="option.value" x-model="answers[4]" class="text-accent-500" />
                  <span class="text-dark-700" style="font-weight: 400;" x-text="option.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Question 6 -->
          <div x-show="currentStep === 6">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Disposez-vous d'une supervision centralisée ? L'intégration multi-lots est un marqueur clé des classes A et B de la norme EN 15232.</h3>
            <div class="space-y-3">
              <template x-for="option in questions[5].options" :key="option.value">
                <label class="flex items-center gap-3 p-4 rounded-xl cursor-pointer" style="border: 0.5px solid rgba(0,0,0,0.08); transition: border-color 0.15s ease;" :style="answers[5] === option.value ? 'border-color: var(--color-accent-500); background: var(--color-accent-50);' : ''">
                  <input type="radio" name="q6" :value="option.value" x-model="answers[5]" class="text-accent-500" />
                  <span class="text-dark-700" style="font-weight: 400;" x-text="option.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Question 7 -->
          <div x-show="currentStep === 7">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Comment gérez-vous la maintenance ? La norme NF EN 13306 distingue quatre niveaux de maturité en maintenance.</h3>
            <div class="space-y-3">
              <template x-for="option in questions[6].options" :key="option.value">
                <label class="flex items-center gap-3 p-4 rounded-xl cursor-pointer" style="border: 0.5px solid rgba(0,0,0,0.08); transition: border-color 0.15s ease;" :style="answers[6] === option.value ? 'border-color: var(--color-accent-500); background: var(--color-accent-50);' : ''">
                  <input type="radio" name="q7" :value="option.value" x-model="answers[6]" class="text-accent-500" />
                  <span class="text-dark-700" style="font-weight: 400;" x-text="option.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Question 8 -->
          <div x-show="currentStep === 8">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Quel est votre niveau de conformité réglementaire ? Le décret BACS (2020) et le décret tertiaire imposent des obligations croissantes.</h3>
            <div class="space-y-3">
              <template x-for="option in questions[7].options" :key="option.value">
                <label class="flex items-center gap-3 p-4 rounded-xl cursor-pointer" style="border: 0.5px solid rgba(0,0,0,0.08); transition: border-color 0.15s ease;" :style="answers[7] === option.value ? 'border-color: var(--color-accent-500); background: var(--color-accent-50);' : ''">
                  <input type="radio" name="q8" :value="option.value" x-model="answers[7]" class="text-accent-500" />
                  <span class="text-dark-700" style="font-weight: 400;" x-text="option.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Navigation -->
          <div class="flex justify-between mt-8">
            <button x-show="currentStep > 1" @click="currentStep--" class="px-6 py-2 text-dark-600 font-medium rounded-xl" style="border: 0.5px solid rgba(0,0,0,0.08); transition: background 0.15s ease;">
              Précédent
            </button>
            <div x-show="currentStep === 1"></div>
            <button x-show="currentStep < totalSteps" @click="if(answers[currentStep-1]) currentStep++" :class="answers[currentStep-1] ? 'bg-accent-500 text-white' : 'bg-dark-100 text-dark-400 cursor-not-allowed'" class="px-6 py-2 font-medium rounded-xl" style="transition: opacity 0.15s ease;">
              Suivant
            </button>
            <button x-show="currentStep === totalSteps" @click="calculateResults()" :class="answers[currentStep-1] ? 'bg-accent-500 text-white' : 'bg-dark-100 text-dark-400 cursor-not-allowed'" class="px-6 py-2 font-medium rounded-xl" style="transition: opacity 0.15s ease;">
              Voir les résultats
            </button>
          </div>
        </div>

        <!-- Results -->
        <div x-show="showResults" class="space-y-8">
          <div class="bg-white rounded-xl p-8 text-center" style="border: 0.5px solid rgba(0,0,0,0.08);">
            <h2 class="text-2xl font-heading font-medium text-dark-900">Résultat de votre diagnostic EN 15232</h2>

            <!-- Score -->
            <div class="mt-8">
              <div class="inline-flex items-center justify-center w-32 h-32 rounded-full" style="border: 2px solid rgba(0,0,0,0.08);" :class="scoreColor">
                <div>
                  <div class="text-3xl font-heading font-medium" :class="scoreTextColor" x-text="score + '/100'"></div>
                </div>
              </div>
            </div>

            <div class="mt-6">
              <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium" :class="levelBadge" x-text="level"></span>
            </div>

            <p class="mt-4 text-dark-500 max-w-lg mx-auto" style="font-weight: 400;" x-text="levelDescription"></p>
          </div>

          <!-- Recommandations -->
          <div class="bg-white rounded-xl p-8" style="border: 0.5px solid rgba(0,0,0,0.08);">
            <h3 class="text-xl font-heading font-medium text-dark-900 mb-6">Recommandations personnalisées</h3>
            <div class="space-y-3">
              <template x-for="rec in recommendations" :key="rec">
                <div class="flex items-start gap-3 p-4 rounded-xl" style="border: 0.5px solid rgba(0,0,0,0.08);">
                  <svg class="w-5 h-5 text-accent-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <p class="text-dark-600 text-sm" style="font-weight: 400;" x-text="rec"></p>
                </div>
              </template>
            </div>
          </div>

          <!-- CTA -->
          <div class="text-center space-y-4">
            <button @click="resetAudit()" class="px-6 py-3 text-dark-600 font-medium rounded-xl" style="border: 0.5px solid rgba(0,0,0,0.08); transition: background 0.15s ease;">
              Refaire le diagnostic
            </button>
            <a href="/contact" class="btn-primary ml-4">
              Demander un conseil personnalisé
            </a>
          </div>
        </div>

      </div>

    </div>
  </section>

  <script>
    document.addEventListener('alpine:init', () => {
      Alpine.data('auditWizard', () => ({
        currentStep: 1,
        totalSteps: 8,
        showResults: false,
        score: 0,
        level: '',
        levelDescription: '',
        scoreColor: '',
        scoreTextColor: '',
        levelBadge: '',
        recommendations: [],
        answers: {},
        questions: [
          {
            options: [
              { value: 'bureau', label: 'Bureaux / Tertiaire' },
              { value: 'commerce', label: 'Commerce / Centre commercial' },
              { value: 'industrie', label: 'Industriel / Logistique' },
              { value: 'sante', label: 'Santé / Hôpital' },
              { value: 'education', label: 'Enseignement / Formation' },
              { value: 'hotel', label: 'Hôtellerie / Résidentiel' }
            ]
          },
          {
            options: [
              { value: 'small', label: 'Moins de 1 000 m²' },
              { value: 'medium', label: '1 000 à 5 000 m²' },
              { value: 'large', label: '5 000 à 20 000 m²' },
              { value: 'xlarge', label: 'Plus de 20 000 m²' }
            ]
          },
          {
            options: [
              { value: '0', label: 'Aucune régulation (tout en manuel)' },
              { value: '1', label: 'Régulation basique (thermostats simples)' },
              { value: '2', label: 'Régulation par zone avec programmation horaire' },
              { value: '3', label: 'Régulation avancée avec optimisation automatique' }
            ]
          },
          {
            options: [
              { value: '0', label: 'Interrupteurs manuels uniquement' },
              { value: '1', label: 'Minuteries ou programmation horaire' },
              { value: '2', label: 'Détection de présence et variation d\'intensité' },
              { value: '3', label: 'Gestion intelligente complète (daylight, scénarios)' }
            ]
          },
          {
            options: [
              { value: '0', label: 'Aucun suivi' },
              { value: '1', label: 'Relevé manuel des compteurs' },
              { value: '2', label: 'Sous-comptage automatique par usage' },
              { value: '3', label: 'Monitoring temps reel avec alertes' }
            ]
          },
          {
            options: [
              { value: '0', label: 'Aucune supervision' },
              { value: '1', label: 'Supervision partielle (un seul lot technique)' },
              { value: '2', label: 'GTC centralisée sur plusieurs lots' },
              { value: '3', label: 'GTB complète avec pilotage et optimisation' }
            ]
          },
          {
            options: [
              { value: '0', label: 'Maintenance curative uniquement (on répare quand ça casse)' },
              { value: '1', label: 'Maintenance préventive planifiée' },
              { value: '2', label: 'Maintenance conditionnelle (basée sur les données)' },
              { value: '3', label: 'Maintenance prédictive (anticipation des pannes)' }
            ]
          },
          {
            options: [
              { value: '0', label: 'Je ne connais pas les obligations réglementaires' },
              { value: '1', label: 'Connaissance partielle, conformité incertaine' },
              { value: '2', label: 'Conforme au décret tertiaire, RE2020 en cours' },
              { value: '3', label: 'Pleinement conforme avec reporting automatisé' }
            ]
          }
        ],

        calculateResults() {
          let total = 0;
          for (let i = 2; i < 8; i++) {
            total += parseInt(this.answers[i] || 0);
          }
          this.score = Math.round((total / 18) * 100);

          if (this.score < 25) {
            this.level = 'Classe D — Non performant (EN 15232)';
            this.levelDescription = 'Votre bâtiment ne dispose pas de système de gestion technique conforme. Selon la norme EN 15232, il se situe en classe D. Le potentiel d\'optimisation énergétique est estimé entre 30 et 50 % par rapport à une GTB de classe A.';
            this.scoreColor = 'border-dark-300';
            this.scoreTextColor = 'text-dark-600';
            this.levelBadge = 'bg-dark-100 text-dark-700';
            this.recommendations = [
              'Réaliser un audit énergétique conforme à la norme NF EN 16247-2 (bâtiments)',
              'Installer des capteurs de température et de présence dans les zones principales pour amorcer une régulation automatisée',
              'Mettre en place un suivi des consommations énergétiques par sous-comptage, prérequis du décret tertiaire (plateforme OPERAT)',
              'Étudier la faisabilité d\'une GTB de classe C minimum selon EN 15232, obligation du décret BACS pour les bâtiments > 290 kW',
              'Vérifier vos obligations réglementaires : décret tertiaire (échéance -40 % en 2030), décret BACS (échéance 2025/2027)',
              'Identifier les CEE (Certificats d\'Économies d\'Énergie) mobilisables pour financer la mise en conformité'
            ];
          } else if (this.score < 50) {
            this.level = 'Classe C — Standard (EN 15232)';
            this.levelDescription = 'Votre bâtiment dispose d\'une automatisation de base, correspondant à la classe C de la norme EN 15232. Des améliorations vers la classe B permettraient une réduction supplémentaire de 10 à 20 % des consommations.';
            this.scoreColor = 'border-orange-300';
            this.scoreTextColor = 'text-orange-600';
            this.levelBadge = 'bg-orange-50 text-orange-700';
            this.recommendations = [
              'Centraliser la supervision de vos lots techniques sur une GTC unique avec protocole BACnet/IP ou KNX pour l\'interopérabilité',
              'Améliorer la régulation CVC avec des capteurs de qualité d\'air (CO2) conformément à la norme NF EN 16798-1',
              'Mettre en place un suivi énergétique automatisé avec alertes de dérive, conforme aux exigences du décret tertiaire',
              'Passer à une maintenance conditionnelle basée sur les données (norme NF EN 13306) pour réduire les coûts de 15 à 25 %',
              'Former vos équipes techniques à l\'exploitation de la GTB selon le référentiel de compétences AFPAC',
              'Étudier la migration vers une classe B EN 15232 en priorité sur les lots CVC et éclairage'
            ];
          } else if (this.score < 75) {
            this.level = 'Classe B — Avancé (EN 15232)';
            this.levelDescription = 'Votre bâtiment dispose d\'une GTB performante de classe B selon EN 15232. Quelques optimisations ciblées peuvent vous rapprocher de la classe A et d\'économies supplémentaires de 5 à 15 %.';
            this.scoreColor = 'border-primary-300';
            this.scoreTextColor = 'text-primary-600';
            this.levelBadge = 'bg-primary-50 text-primary-700';
            this.recommendations = [
              'Explorer les solutions d\'intelligence artificielle pour l\'optimisation prédictive des courbes de charge (norme ISO 50001)',
              'Mettre en place un jumeau numérique de votre bâtiment pour simuler et optimiser les scénarios énergétiques',
              'Optimiser les scénarios de fonctionnement selon l\'occupation réelle mesurée par capteurs IoT (protocole LoRaWAN ou Zigbee)',
              'Envisager l\'intégration de capteurs IoT supplémentaires pour un maillage plus fin et une granularité conforme à l\'ISO 52120-1',
              'Automatiser le reporting réglementaire (décret tertiaire, plateforme OPERAT) et le suivi des objectifs 2030/2040',
              'Évaluer la conformité au label R2S-4GRIDS pour valoriser votre démarche Smart Building'
            ];
          } else {
            this.level = 'Classe A — Haute performance (EN 15232)';
            this.levelDescription = 'Votre bâtiment atteint la classe A de la norme EN 15232, le niveau le plus élevé d\'automatisation et de gestion énergétique. Vous êtes conforme aux exigences les plus strictes du décret BACS.';
            this.scoreColor = 'border-accent-300';
            this.scoreTextColor = 'text-accent-600';
            this.levelBadge = 'bg-accent-50 text-accent-700';
            this.recommendations = [
              'Partager votre retour d\'expérience pour inspirer le secteur et contribuer aux travaux normatifs (AFNOR, CEN TC 247)',
              'Explorer les dernières innovations : IA générative pour l\'optimisation, protocole Matter pour l\'interopérabilité, blockchain énergie pour la traçabilité',
              'Optimiser continuellement via l\'analyse des données historiques et le machine learning conforme à la norme ISO 50006',
              'Étendre votre approche GTB classe A à l\'ensemble de votre parc immobilier pour un impact global mesurable',
              'Viser les certifications environnementales (HQE Bâtiment Durable, BREEAM In-Use, LEED O+M) en capitalisant sur votre infrastructure GTB',
              'Mettre en place un système de management de l\'énergie certifié ISO 50001 pour pérenniser la démarche'
            ];
          }

          this.showResults = true;
        },

        resetAudit() {
          this.currentStep = 1;
          this.showResults = false;
          this.score = 0;
          this.answers = {};
        }
      }));
    });
  </script>

  <RelatedPages links={[
    { href: "/comparateur", title: "Comparateur GTB", description: "Comparez les solutions après votre diagnostic." },
    { href: "/gtb", title: "Qu'est-ce que la GTB ?", description: "Tout comprendre sur la Gestion Technique du Bâtiment." },
    { href: "/generateur-cee", title: "Simulateur CEE", description: "Estimez vos primes pour financer votre projet GTB." },
  ]} />

</Layout>
