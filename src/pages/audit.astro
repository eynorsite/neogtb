  /* ── Focus states for buttons ── */
  .diag-btn-primary:focus-visible,
  .diag-btn-accent:focus-visible,
  .diag-btn-ghost:focus-visible {
    outline: 2px solid var(--color-accent-500);
    outline-offset: 2px;
  }

  /* ── iOS: prevent auto-zoom on input focus (requires 16px min) ── */
  @media screen and (-webkit-min-device-pixel-ratio: 0) {
    .diag-input, .diag-input-sm, select { font-size: 16px !important; }
  }

  /* ── Modal ── */
  .diag-modal-overlay {
    position: fixed; inset: 0; z-index: 70;
    display: flex; align-items: center; justify-content: center;
    padding: 16px; background: rgba(15, 23, 42, 0.5); backdrop-filter: blur(8px);
  }
