  }
  .diag-premium-list li::before { content: '✓ '; color: var(--color-accent-500); font-weight: 700; }
  .diag-premium-price { font-size: 20px; font-weight: 600; color: var(--color-dark-900); }

  /* ── Disclaimer ── */
  .diag-disclaimer {
    display: flex; gap: 12px; padding: 16px 20px;
