    background: white; border-radius: 16px;
    max-width: 420px; width: 100%; padding: 28px;
    border: 1px solid var(--color-dark-200);
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  }
  @media (max-width: 480px) {
    .diag-modal { max-width: 100%; padding: 20px; }
    .diag-modal-overlay { padding: 12px; }
  }
</style>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('diagWizard', () => ({
      step: 1,
      totalSteps: 4,
      currentQuestion: 0,
      animatedScore: 0,
      stepLabels: ['Bâtiment', 'Consommations', 'Maturité GTB', 'Résultats'],
      errors: {},
      showEmailModal: false,
      emailAddress: '',
      userName: '',
      userCompany: '',
      emailSent: false,

      buildingTypes: [
        { id: 'bureau', label: 'Bureaux', icon: '🏢' },
        { id: 'commerce', label: 'Commerce', icon: '🛒' },
        { id: 'industrie', label: 'Industrie', icon: '🏭' },
        { id: 'sante', label: 'Santé', icon: '🏥' },
        { id: 'education', label: 'Enseignement', icon: '🏫' },
        { id: 'hotel', label: 'Hôtellerie', icon: '🏨' },
      ],

      energyLabels: {
        electricite: { label: 'Électricité', icon: '⚡' },
        gaz: { label: 'Gaz naturel', icon: '🔥' },
        fioul: { label: 'Fioul domestique', icon: '🛢️' },
        chauffage_urbain: { label: 'Chauffage urbain', icon: '🌡️' },
        froid_urbain: { label: 'Froid urbain', icon: '❄️' },
        bois: { label: 'Bois / Biomasse', icon: '🪵' },
      },

      // Références kWh EF/m²/an par type [performant, moyen, énergivore]
      // Sources :
      // - Bureaux : OID/ADEME Baromètre 2022 (146 kWh EF moyen), Décret tertiaire Cabs 2030 = 107 kWh
      // - Commerce : ADEME fourchette 200-400 (Covalba/ADEME 2024)
      // - Industrie : variable, hors périmètre décret tertiaire strict
      // - Santé : ADEME 2024 — secteur le + énergivore du tertiaire, fourchette 300-700
      // - Enseignement : OPERAT 2021 — moyenne 118, médiane 109 kWh/m²/an
      // - Hôtellerie : estimation 200-400 kWh/m²/an
      ademeRefs: {
        bureau:     [107, 170, 300],
        commerce:   [160, 280, 450],
        industrie:  [100, 220, 400],
        sante:      [200, 400, 700],
        education:  [80, 118, 230],
        hotel:      [150, 260, 420],
      },

      // Puissance CVC estimée par m² (kW/m²) pour estimation décret BACS
      // En pratique : ~0.05 à 0.15 kW/m² selon bâtiment
      puissanceRatios: {
        bureau: 0.07, commerce: 0.09, industrie: 0.06,
        sante: 0.12, education: 0.06, hotel: 0.10,
      },

      gtbQuestions: [
        {
          title: 'Régulation CVC — Disposez-vous d\'un système de régulation du chauffage, ventilation et climatisation ?',
          options: [
            { value: 0, label: 'Aucune régulation (tout en manuel)' },
            { value: 1, label: 'Régulation basique (thermostats simples)' },
            { value: 2, label: 'Régulation par zone avec programmation horaire' },
            { value: 3, label: 'Régulation avancée avec optimisation automatique' },
          ]
        },
        {
          title: 'Éclairage — Comment est géré l\'éclairage de votre bâtiment ?',
          options: [
            { value: 0, label: 'Interrupteurs manuels uniquement' },
            { value: 1, label: 'Minuteries ou programmation horaire' },
            { value: 2, label: 'Détection de présence et variation d\'intensité' },
            { value: 3, label: 'Gestion intelligente complète (daylight harvesting, scénarios)' },
          ]
        },
        {
          title: 'Suivi des consommations — Avez-vous un suivi énergétique en place ?',
          options: [
            { value: 0, label: 'Aucun suivi' },
            { value: 1, label: 'Relevé manuel des compteurs' },
            { value: 2, label: 'Sous-comptage automatique par usage' },
            { value: 3, label: 'Monitoring temps réel avec alertes de dérive' },
          ]
        },
        {
          title: 'Supervision — Disposez-vous d\'une supervision centralisée des lots techniques ?',
          options: [
            { value: 0, label: 'Aucune supervision' },
            { value: 1, label: 'Supervision partielle (un seul lot technique)' },
            { value: 2, label: 'GTC centralisée sur plusieurs lots' },
            { value: 3, label: 'GTB complète avec pilotage et optimisation multi-lots' },
          ]
        },
        {
          title: 'Maintenance — Quel est votre mode de maintenance dominant ?',
          options: [
            { value: 0, label: 'Curative uniquement (on répare quand ça casse)' },
            { value: 1, label: 'Préventive planifiée' },
            { value: 2, label: 'Conditionnelle (basée sur les données capteurs)' },
            { value: 3, label: 'Prédictive (anticipation des pannes par IA/analyse)' },
          ]
        },
        {
          title: 'Conformité — Quel est votre niveau de connaissance et conformité réglementaire ?',
          options: [
            { value: 0, label: 'Je ne connais pas les obligations réglementaires' },
            { value: 1, label: 'Connaissance partielle, conformité incertaine' },
            { value: 2, label: 'Conforme au décret tertiaire, BACS en cours' },
            { value: 3, label: 'Pleinement conforme avec reporting automatisé (OPERAT)' },
          ]
        },
      ],

      form: {
        buildingType: '',
        surface: null,
        buildingAge: '',
        climateZone: '',
        energies: [{ type: '', conso: null, facture: null }],
        gtbAnswers: {},
      },

      // Coefficients CEE pour estimation prime GTB
      // Fiches : BAT-TH-116 (GTB CVC), BAT-TH-145 (clim), BAT-EQ-127 (éclairage)
      // Prix CEE : 6,50 €/MWh cumac
      // Coefficients zone/âge identiques au générateur CEE
      ceeZoneCoeff: { 'H1': 1.3, 'H2': 1.0, 'H3': 0.7 },
      ceeAgeCoeff: { 'before1975': 1.5, '1975-2000': 1.2, '2000-2012': 1.0, 'after2012': 0.6 },
      ceeTypeCoeff: { 'bureau': 1.0, 'commerce': 0.9, 'industrie': 1.3, 'sante': 1.4, 'education': 1.1, 'hotel': 1.2 },
      ceePricePerMwh: 6.50, // €/MWh cumac

      results: {
        score: 0, levelKey: 'd', levelLabel: '', levelDescription: '',
        savingsEuro: 0, savingsPercent: 0,
        totalConso: 0, totalFacture: 0,
        energySummary: [],
        benchmark: { kwhM2: 0, position: 50, refGood: 0, refAvg: 0, refBad: 0, goodPercent: 33, avgPercent: 34, badPercent: 33 },
        regulatory: { show: false, severity: 'ok', title: '', text: '', daysLeft: 0 },
        recommendations: [],
        cee: { gwh: 0, valueLow: 0, valueHigh: 0, eligible: false, fiches: [] },
      },

      formatNumber(n) { if (!n) return '0'; return new Intl.NumberFormat('fr-FR').format(Math.round(n)); },
      formatCurrency(n) { return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n || 0); },

      selectAnswer(qi, value) {
        this.form.gtbAnswers[qi] = value;
        // Auto-avance après 800ms si pas dernière question
        if (qi < this.gtbQuestions.length - 1) {
          setTimeout(() => { this.nextQuestion(); }, 800);
        }
      },

      nextQuestion() {
        if (this.form.gtbAnswers[this.currentQuestion] !== undefined && this.currentQuestion < this.gtbQuestions.length - 1) {
          this.currentQuestion++;
        }
      },

      validateStep1() {
        this.errors = {};
        if (!this.form.buildingType) this.errors.buildingType = 'Sélectionnez un type';
        if (!this.form.surface || this.form.surface < 50) this.errors.surface = 'Surface minimale : 50 m²';
        if (!this.form.climateZone) this.errors.climateZone = 'Sélectionnez une zone';
        if (!this.form.buildingAge) this.errors.buildingAge = 'Sélectionnez une période';
        if (Object.keys(this.errors).length === 0) { this.step = 2; window.scrollTo({ top: 0, behavior: 'smooth' }); }
      },

      validateStep2() {
        this.errors = {};
        const validEnergies = this.form.energies.filter(e => e.type && e.conso > 0);
        if (validEnergies.length === 0) { this.errors.energies = 'Renseignez au moins une énergie avec sa consommation.'; return; }
        this.step = 3; window.scrollTo({ top: 0, behavior: 'smooth' });
      },

      validateStep3() {
        this.errors = {};
        const answered = Object.keys(this.form.gtbAnswers).length;
        if (answered < this.gtbQuestions.length) {
          this.errors.gtb = 'Répondez à toutes les questions.';
          return;
        }
        this.calculateResults();
        this.animatedScore = 0;
        this.step = 4;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        // Pré-charger jsPDF et logo en arrière-plan pour que le PDF soit instantané au clic
        if (!window._jsPDFModule) { import('jspdf').then(m => { window._jsPDFModule = m; }); }
        if (!window._neogtbLogo) { const img = new Image(); img.src = '/images/logo-neogtb-pdf.png'; img.onload = () => { window._neogtbLogo = img; }; }
        // Animation compteur score
        const target = this.results.score;
        const self = this;
        let current = 0;
        const interval = setInterval(() => {
          current += Math.ceil(target / 25);
          if (current >= target) { current = target; clearInterval(interval); }
          self.animatedScore = current;
        }, 30);
        // Sauvegarder en localStorage pour les autres outils
        try {
          localStorage.setItem('neogtb_diag', JSON.stringify({
            buildingType: this.form.buildingType,
            surface: this.form.surface,
            buildingAge: this.form.buildingAge,
            climateZone: this.form.climateZone,
            score: this.results.score,
            levelKey: this.results.levelKey,
          }));
        } catch(e) {}
      },

      calculateResults() {
        // 1. Score GTB (maturité)
        let gtbTotal = 0;
        for (let i = 0; i < this.gtbQuestions.length; i++) {
          gtbTotal += parseInt(this.form.gtbAnswers[i] || 0);
        }
        const maxGtb = this.gtbQuestions.length * 3;

        // 2. Totaux énergie
        // Prix moyens €/kWh pour estimer la facture si non renseignée
        // Sources : CRE/Eurostat 2024 — tarifs moyens entreprises France
        const prixMoyenKwh = {
          electricite: 0.18, gaz: 0.08, fioul: 0.10,
          chauffage_urbain: 0.09, froid_urbain: 0.11, bois: 0.05,
        };
        let totalConso = 0, totalFacture = 0;
        const energySummary = [];
        for (const e of this.form.energies) {
          if (e.type && e.conso > 0) {
            totalConso += e.conso;
            // Si facture non renseignée, estimer depuis la conso × prix moyen
            const facture = (e.facture && e.facture > 0) ? e.facture : Math.round(e.conso * (prixMoyenKwh[e.type] || 0.12));
            totalFacture += facture;
            const info = this.energyLabels[e.type] || { label: e.type, icon: '⚡' };
            energySummary.push({ label: info.label, icon: info.icon, conso: e.conso, facture: facture, estimated: !(e.facture && e.facture > 0) });
          }
        }
        this.results.totalConso = totalConso;
        this.results.totalFacture = totalFacture;
        this.results.energySummary = energySummary;

        // 3. Benchmark ADEME
        const refs = this.ademeRefs[this.form.buildingType] || [100, 200, 350];
        const kwhM2 = this.form.surface > 0 ? totalConso / this.form.surface : 0;
        this.results.benchmark.kwhM2 = kwhM2;
        this.results.benchmark.refGood = refs[0];
        this.results.benchmark.refAvg = refs[1];
        this.results.benchmark.refBad = refs[2];
        const barMax = refs[2] * 1.3;
        const rawGood = (refs[0] / barMax) * 100;
        const rawAvg = ((refs[1] - refs[0]) / barMax) * 100;
        const rawBad = 100 - rawGood - rawAvg;
        // Arrondi contrôlé : badPercent absorbe les erreurs pour que la somme = 100%
        this.results.benchmark.goodPercent = Math.floor(rawGood);
        this.results.benchmark.avgPercent = Math.floor(rawAvg);
        this.results.benchmark.badPercent = 100 - this.results.benchmark.goodPercent - this.results.benchmark.avgPercent;
        this.results.benchmark.position = Math.min(98, Math.max(2, Math.round((kwhM2 / barMax) * 100)));

        // 4. Score EN 15232 = basé sur la maturité GTB uniquement
        // La norme EN 15232 / ISO 52120-1 classe le NIVEAU D'AUTOMATISATION, pas la conso.
        // Pondération par importance pour la classification :
        //   - Régulation CVC (q0) : x2 — critère central EN 15232
        //   - Supervision (q3) : x2 — marqueur clé classes A/B
        //   - Éclairage (q1), Suivi conso (q2), Maintenance (q4), Conformité (q5) : x1
        const weights = [2, 1, 1, 2, 1, 1]; // CVC x2, supervision x2
        let weightedTotal = 0, weightedMax = 0;
        for (let i = 0; i < this.gtbQuestions.length; i++) {
          weightedTotal += parseInt(this.form.gtbAnswers[i] || 0) * weights[i];
          weightedMax += 3 * weights[i];
        }
        const score = Math.round((weightedTotal / weightedMax) * 100);
        this.results.score = score;

        // Score énergie séparé (pour affichage benchmark, pas pour la classe)
        let energyRating = '';
        if (kwhM2 <= refs[0]) energyRating = 'performant';
        else if (kwhM2 <= refs[1]) energyRating = 'moyen';
        else energyRating = 'énergivore';
        this.results.energyRating = energyRating;

        // 5. Niveau EN 15232
        // Seuils alignés sur la logique EN 15232 / ISO 52120-1 :
        //   D (< 25%) : pas d'automatisation ou fonctions de base manuelles
        //   C (25-50%) : automatisation standard, régulation basique
        //   B (50-75%) : système avancé, GTC centralisée multi-lots
        //   A (≥ 75%) : haute performance, GTB complète avec optimisation
        if (score < 25) {
          this.results.levelKey = 'd';
          this.results.levelLabel = 'Classe D — Non performant';
          this.results.levelDescription = 'Votre bâtiment ne dispose pas de gestion technique conforme. Le potentiel d\'optimisation est estimé entre 30 et 50 % selon la norme EN 15232.';
        } else if (score < 50) {
          this.results.levelKey = 'c';
          this.results.levelLabel = 'Classe C — Standard';
          this.results.levelDescription = 'Automatisation de base correspondant à la classe C. Un passage en classe B permettrait 10 à 20 % d\'économies supplémentaires.';
        } else if (score < 75) {
          this.results.levelKey = 'b';
          this.results.levelLabel = 'Classe B — Avancé';
          this.results.levelDescription = 'GTB performante de classe B. Quelques optimisations ciblées peuvent vous rapprocher de la classe A et d\'économies supplémentaires de 5 à 15 %.';
        } else {
          this.results.levelKey = 'a';
          this.results.levelLabel = 'Classe A — Haute performance';
          this.results.levelDescription = 'Niveau le plus élevé d\'automatisation (EN 15232). Vous êtes conforme aux exigences les plus strictes du décret BACS.';
        }

        // 6. Économies potentielles
        // Basé sur NF EN ISO 52120-1:2022 (ex EN 15232)
        // Classe D → A : ~30% thermique + 13% électrique ≈ 25-30% global
        // Classe C → A : ~30% thermique + 13% électrique ≈ 25% global
        // Classe C → B : ~20% thermique + 7% électrique ≈ 15% global
        // Classe B → A : ~10% thermique + 6% électrique ≈ 8% global
        // Source : calculcee.fr / NF EN ISO 52120-1:2022
        let savingsPercent = 0;
        if (score < 25) savingsPercent = 30;       // D → passage en A
        else if (score < 50) savingsPercent = 25;   // C → passage en A
        else if (score < 75) savingsPercent = 15;   // B → passage en A
        else savingsPercent = 5;                     // A — optimisation continue
        this.results.savingsPercent = savingsPercent;
        this.results.savingsEuro = Math.round(totalFacture * savingsPercent / 100);

        // 6b. Estimation prime CEE — cumul des fiches applicables
        // Éligible si le bâtiment n'est pas déjà en classe A
        if (score < 75) {
          const zC = this.ceeZoneCoeff[this.form.climateZone] || 1;
          const aC = this.ceeAgeCoeff[this.form.buildingAge] || 1;
          const tC = this.ceeTypeCoeff[this.form.buildingType] || 1;
          const surf = this.form.surface;

          // Fiches CEE applicables selon le niveau de maturité
          // Réponses GTB : 0=régulation CVC, 1=éclairage, 2=suivi conso, 3=supervision
          const cvcScore = parseInt(this.form.gtbAnswers[0] || 0);   // régulation CVC
          const eclScore = parseInt(this.form.gtbAnswers[1] || 0);   // éclairage

          const fiches = [];

          // BAT-TH-116 : GTB / régulation CVC — applicable si CVC pas déjà optimisé (score < 3)
          if (cvcScore < 3) {
            const gwh = 0.042 * surf * zC * aC * tC / 1000;
            fiches.push({ fiche: 'BAT-TH-116', label: 'GTB régulation CVC', gwh });
          }

          // BAT-TH-145 : Climatisation performante — applicable si CVC basique (score < 2)
          if (cvcScore < 2) {
            const gwh = 0.028 * surf * zC * aC * tC / 1000;
            fiches.push({ fiche: 'BAT-TH-145', label: 'Climatisation performante', gwh });
          }

          // BAT-EQ-127 : Éclairage performant — applicable si éclairage pas intelligent (score < 2)
          if (eclScore < 2) {
            const gwh = 0.018 * surf * zC * aC * tC / 1000;
            fiches.push({ fiche: 'BAT-EQ-127', label: 'Éclairage performant', gwh });
          }

          const totalGwh = fiches.reduce((sum, f) => sum + f.gwh, 0);
          const valueBase = totalGwh * this.ceePricePerMwh * 1000;

          this.results.cee = {
            gwh: totalGwh,
            valueLow: Math.round(valueBase * 0.75),
            valueHigh: Math.round(valueBase * 1.25),
            eligible: fiches.length > 0,
            fiches: fiches,
          };
        } else {
          this.results.cee = { gwh: 0, valueLow: 0, valueHigh: 0, eligible: false, fiches: [] };
        }

        // 7. Urgence réglementaire (décret BACS)
        const puissanceKW = this.form.surface * (this.puissanceRatios[this.form.buildingType] || 0.07);
        const now = new Date();
        if (puissanceKW >= 290) {
          this.results.regulatory = {
            show: true, severity: 'critical',
            title: 'Obligation GTB dépassée — décret BACS',
            text: `Puissance CVC estimée : ${Math.round(puissanceKW)} kW (> 290 kW). L'obligation de GTB de classe C minimum est effective depuis le 1er janvier 2025. Votre bâtiment est potentiellement en infraction.`,
            daysLeft: 0,
          };
        } else if (puissanceKW >= 70) {
          const deadline = new Date('2027-01-01');
          const daysLeft = Math.max(0, Math.ceil((deadline - now) / (1000 * 60 * 60 * 24)));
          this.results.regulatory = {
            show: true, severity: 'warning',
            title: 'Échéance décret BACS — 1er janvier 2027',
            text: `Puissance CVC estimée : ${Math.round(puissanceKW)} kW (> 70 kW). L'obligation GTB de classe C minimum s'appliquera au 1er janvier 2027.`,
            daysLeft,
          };
        } else {
          this.results.regulatory = {
            show: true, severity: 'ok',
            title: 'Pas d\'obligation immédiate',
            text: `Puissance CVC estimée : ${Math.round(puissanceKW)} kW (< 70 kW). Vous n'êtes pas soumis au décret BACS actuellement, mais la directive EPBD européenne pourrait élargir le périmètre.`,
            daysLeft: 0,
          };
        }

        // 8. Recommandations personnalisées
        const recs = [];
        if (score < 25) {
          recs.push('Réaliser un audit énergétique conforme NF EN 16247-2 pour identifier les gisements d\'économies');
          recs.push('Installer des capteurs de température et de présence pour amorcer une régulation automatisée');
          recs.push('Mettre en place un suivi des consommations par sous-comptage (prérequis décret tertiaire, plateforme OPERAT)');
          recs.push('Étudier la faisabilité d\'une GTB de classe C minimum (obligation décret BACS pour > 290 kW)');
          recs.push('Identifier les CEE mobilisables (fiches BAT-TH-116, BAT-TH-145) pour financer la mise en conformité');
        } else if (score < 50) {
          recs.push('Centraliser la supervision sur une GTC unique avec protocole BACnet/IP ou KNX');
          recs.push('Améliorer la régulation CVC avec capteurs CO₂ (norme NF EN 16798-1)');
          recs.push('Automatiser le suivi énergétique avec alertes de dérive (conformité décret tertiaire)');
          recs.push('Passer à une maintenance conditionnelle basée sur les données pour réduire les coûts de 15 à 25 %');
          recs.push('Étudier la migration vers une classe B EN 15232 en priorité sur CVC et éclairage');
        } else if (score < 75) {
          recs.push('Explorer les solutions d\'IA pour l\'optimisation prédictive des courbes de charge (ISO 50001)');
          recs.push('Optimiser les scénarios de fonctionnement selon l\'occupation réelle (capteurs IoT LoRaWAN)');
          recs.push('Automatiser le reporting réglementaire (décret tertiaire, OPERAT) et le suivi des objectifs 2030');
          recs.push('Évaluer la conformité au label R2S-4GRIDS pour valoriser votre démarche Smart Building');
        } else {
          recs.push('Partager votre retour d\'expérience pour contribuer aux travaux normatifs (AFNOR, CEN TC 247)');
          recs.push('Explorer les dernières innovations : IA générative, protocole Matter, blockchain énergie');
          recs.push('Étendre votre approche GTB classe A à l\'ensemble de votre parc immobilier');
          recs.push('Viser les certifications environnementales (HQE, BREEAM In-Use, LEED O+M)');
        }
        // Reco spécifique énergie
        if (kwhM2 > refs[1]) {
          recs.push(`Votre consommation (${Math.round(kwhM2)} kWh/m²/an) dépasse la moyenne ADEME (${refs[1]} kWh/m²/an) — un audit sur site permettrait d'identifier les postes de surconsommation`);
        }
        this.results.recommendations = recs;
      },

      showEmailGate() {
        this.showEmailModal = true;
        this.emailSent = false;
      },

      async downloadPDF() {
        try {
        // Envoyer le lead par email
        if (this.emailAddress && this.emailAddress.includes('@')) {
          try {
            const payload = {
              _subject: 'Nouveau lead Diagnostic GTB — NeoGTB',
              email: this.emailAddress,
              nom: this.userName || 'Non renseigné',
              entreprise: this.userCompany || 'Non renseigné',
              score: this.results.score,
              niveau: this.results.levelLabel,
              surface: this.form.surface,
              batiment: this.form.buildingType,
              economies: this.results.savingsEuro,
            };
            fetch('https://formsubmit.co/ajax/hello@neogtb.fr', {
              method: 'POST', body: JSON.stringify(payload),
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            }).catch(() => {});
          } catch(e) {}
        }

        // Générer le PDF
        // Note : on pré-charge jsPDF et le logo pour éviter les délais async
        // qui peuvent bloquer doc.save() dans certains navigateurs (anti-popup)
        let jsPDFModule = window._jsPDFModule;
        if (!jsPDFModule) {
          jsPDFModule = await import('jspdf');
          window._jsPDFModule = jsPDFModule;
        }
        const { jsPDF } = jsPDFModule;
        const doc = new jsPDF();
        const m = 20;
        const pw = 170;
        let y = m;

        // Logo (pré-chargé ou fallback)
        let logoImg = window._neogtbLogo;
        if (!logoImg) {
          logoImg = new Image();
          logoImg.src = '/images/logo-neogtb-pdf.png';
          try { await new Promise((resolve, reject) => { logoImg.onload = resolve; logoImg.onerror = resolve; setTimeout(resolve, 2000); }); } catch(e) {}
          window._neogtbLogo = logoImg;
        }

        // ── HEADER ──
        doc.setFillColor(27, 58, 92);
        doc.rect(0, 0, 210, 45, 'F');
        try { doc.addImage(logoImg, 'PNG', m, 8, 30, 30); } catch(e) {}
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(20); doc.text('NeoGTB', m + 35, 22);
        doc.setFontSize(9); doc.setTextColor(180, 200, 220);
        doc.text('Conseil independant en Gestion Technique du Batiment', m + 35, 30);
        doc.text('neogtb.fr  |  hello@neogtb.fr  |  06 50 14 32 52', m + 35, 37);

        // Ref + Date
        const ref = crypto.randomUUID ? crypto.randomUUID().slice(0, 8) : Math.random().toString(36).slice(2, 10);
        doc.setFontSize(7); doc.setTextColor(140, 170, 200);
        doc.text('Ref : DIAG-' + ref.toUpperCase(), 190, 10, { align: 'right' });
        doc.text(new Date().toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }), 190, 15, { align: 'right' });

        y = 55;

        // ── TITLE ──
        doc.setFontSize(18); doc.setTextColor(15, 23, 42);
        doc.text('Diagnostic GTB — Rapport de performance', m, y);
        y += 5;
        doc.setDrawColor(13, 148, 136); doc.setLineWidth(1.5); doc.line(m, y, m + 60, y);
        y += 15;

        // ── SCORE CARDS ──
        // Score
        const levelColors = { d: [153, 27, 27], c: [146, 64, 14], b: [6, 95, 70], a: [13, 148, 136] };
        const lc = levelColors[this.results.levelKey] || [15, 23, 42];
        doc.setFillColor(lc[0], lc[1], lc[2]);
        doc.roundedRect(m, y, 80, 38, 4, 4, 'F');
        doc.setFontSize(8); doc.setTextColor(255, 255, 255, 160);
        doc.text('SCORE DE MATURITE GTB', m + 5, y + 10);
        doc.setFontSize(24); doc.setTextColor(255, 255, 255);
        doc.text(this.results.score + ' / 100', m + 5, y + 26);
        doc.setFontSize(9); doc.setTextColor(255, 255, 255, 180);
        doc.text(this.results.levelLabel, m + 5, y + 34);

        // Économies
        doc.setFillColor(28, 25, 23);
        doc.roundedRect(m + 85, y, 85, 38, 4, 4, 'F');
        doc.setFontSize(8); doc.setTextColor(180, 200, 220);
        doc.text('ECONOMIES POTENTIELLES', m + 90, y + 10);
        doc.setFontSize(22); doc.setTextColor(255, 255, 255);
        doc.text(this.formatCurrency(this.results.savingsEuro) + ' /an', m + 90, y + 26);
        doc.setFontSize(9); doc.setTextColor(180, 200, 220);
        doc.text('soit ' + this.results.savingsPercent + '% de vos depenses energie', m + 90, y + 34);

        y += 50;

        // ── PRIME CEE ──
        if (this.results.cee.eligible) {
          const fichesText = this.results.cee.fiches.map(f => f.fiche).join(' + ');
          const ceeH = 24;
          doc.setFillColor(255, 251, 235);
          doc.roundedRect(m, y, pw, ceeH, 4, 4, 'F');
          doc.setDrawColor(217, 119, 6); doc.setLineWidth(0.3);
          doc.roundedRect(m, y, pw, ceeH, 4, 4, 'S');
          doc.setFontSize(8); doc.setTextColor(146, 64, 14);
          doc.text('PRIMES CEE ESTIMEES — ' + fichesText, m + 5, y + 7);
          doc.setFontSize(14); doc.setTextColor(180, 90, 0);
          doc.text(this.formatCurrency(this.results.cee.valueLow) + ' — ' + this.formatCurrency(this.results.cee.valueHigh), m + 5, y + 15);
          doc.setFontSize(8); doc.setTextColor(146, 64, 14);
          doc.text('Volume total : ' + this.formatNumber(this.results.cee.gwh * 1000) + ' MWh cumac | Cours : 6,50 EUR/MWh cumac', m + 5, y + 21);
          y += ceeH + 4;
        }

        // ── PARAMETERS ──
        doc.setFillColor(248, 250, 252);
        doc.roundedRect(m, y, pw, 32, 4, 4, 'F');
        doc.setFontSize(10); doc.setTextColor(15, 23, 42); doc.text('Parametres du batiment', m + 5, y + 10);
        y += 15;
        doc.setFontSize(9);
        const bType = this.buildingTypes.find(b => b.id === this.form.buildingType);
        const ageLabels = { 'before1975': 'Avant 1975', '1975-2000': '1975-2000', '2000-2012': '2000-2012', 'after2012': 'Apres 2012' };
        const params = [['Type', bType ? bType.label : ''], ['Surface', this.formatNumber(this.form.surface) + ' m\u00B2'], ['Zone', this.form.climateZone], ['Construction', ageLabels[this.form.buildingAge] || '']];
        for (const [label, val] of params) {
          doc.setTextColor(100, 116, 139); doc.text(label, m + 5, y);
          doc.setTextColor(15, 23, 42); doc.text(val, m + 50, y);
          y += 5;
        }
        y += 10;

        // ── ENERGIES ──
        doc.setFontSize(10); doc.setTextColor(15, 23, 42); doc.text('Consommations declarees', m, y);
        y += 8;
        doc.setFillColor(27, 58, 92);
        doc.roundedRect(m, y, pw, 8, 2, 2, 'F');
        doc.setFontSize(8); doc.setTextColor(255, 255, 255);
        doc.text('ENERGIE', m + 3, y + 5.5);
        doc.text('CONSOMMATION', 100, y + 5.5);
        doc.text('FACTURE', 155, y + 5.5);
        y += 11;
        doc.setFontSize(9);
        let rowIdx = 0;
        for (const e of this.results.energySummary) {
          if (rowIdx % 2 === 0) { doc.setFillColor(248, 250, 252); doc.rect(m, y - 4, pw, 8, 'F'); }
          doc.setTextColor(15, 23, 42); doc.text(e.label, m + 3, y);
          doc.setTextColor(100, 116, 139); doc.text(this.formatNumber(e.conso) + ' kWh', 100, y);
          doc.setTextColor(13, 148, 136); doc.text(this.formatCurrency(e.facture) + ' /an', 155, y);
          y += 8; rowIdx++;
        }

        y += 8;

        // ── BENCHMARK ──
        doc.setFontSize(10); doc.setTextColor(15, 23, 42); doc.text('Benchmark ADEME', m, y);
        y += 5;
        doc.setFontSize(9); doc.setTextColor(100, 116, 139);
        doc.text('Votre batiment : ' + Math.round(this.results.benchmark.kwhM2) + ' kWh/m\u00B2/an', m, y);
        doc.text('Reference performant : ' + this.results.benchmark.refGood + ' kWh/m\u00B2/an  |  Moyen : ' + this.results.benchmark.refAvg + '  |  Energivore : ' + this.results.benchmark.refBad, m, y + 5);
        y += 14;

        // ── REGULATORY ──
        if (this.results.regulatory.show) {
          const regColors = { critical: [254, 226, 226], warning: [255, 251, 235], ok: [240, 253, 244] };
          const regTextColors = { critical: [127, 29, 29], warning: [120, 53, 15], ok: [20, 83, 45] };
          const rc = regColors[this.results.regulatory.severity] || [240, 240, 240];
          const rtc = regTextColors[this.results.regulatory.severity] || [15, 23, 42];
          const regLines = doc.splitTextToSize(this.results.regulatory.text, pw - 10);
          const regH = 10 + regLines.length * 4;
          if (y + regH > 270) { doc.addPage(); y = m; }
          doc.setFillColor(rc[0], rc[1], rc[2]);
          doc.roundedRect(m, y, pw, regH, 4, 4, 'F');
          doc.setFontSize(9); doc.setTextColor(rtc[0], rtc[1], rtc[2]);
          doc.text(this.results.regulatory.title, m + 5, y + 7);
          doc.setFontSize(8);
          doc.text(regLines, m + 5, y + 13);
          y += regH + 4;
        }

        // ── RECOMMENDATIONS ──
        if (y > 260) { doc.addPage(); y = m; }
        doc.setFontSize(10); doc.setTextColor(15, 23, 42); doc.text('Recommandations', m, y);
        y += 7;
        doc.setFontSize(8.5); doc.setTextColor(68, 64, 60);
        for (const rec of this.results.recommendations) {
          const lines = doc.splitTextToSize('\u2022  ' + rec, pw - 5);
          const lineH = lines.length * 4.5 + 2;
          if (y + lineH > 270) { doc.addPage(); y = m; }
          doc.text(lines, m + 2, y);
          y += lineH;
        }

        // ── UPSELL BANNER ──
        if (y + 20 > 270) { doc.addPage(); y = m; }
        y = Math.max(y + 5, y);
        doc.setFillColor(240, 253, 250);
        doc.roundedRect(m, y, pw, 18, 4, 4, 'F');
        doc.setDrawColor(13, 148, 136); doc.setLineWidth(0.5);
        doc.roundedRect(m, y, pw, 18, 4, 4, 'S');
        doc.setFontSize(9); doc.setTextColor(15, 118, 110);
        doc.text('Pour un diagnostic approfondi avec mesures terrain :', m + 5, y + 7);
        doc.setFontSize(8); doc.setTextColor(13, 148, 136);
        doc.text('Demandez un audit sur site par un expert NeoGTB independant  →  neogtb.fr/contact', m + 5, y + 13);

        // ── FOOTER ──
        doc.setFillColor(27, 58, 92);
        doc.rect(0, 282, 210, 15, 'F');
        doc.setFontSize(7); doc.setTextColor(180, 200, 220);
        doc.text('NeoGTB — neogtb.fr — Conseil independant en GTB — EYNOR EURL, Eysines (33)', 105, 289, { align: 'center' });
        doc.setTextColor(140, 170, 200);
        doc.text('Estimation indicative. Sources : OID/ADEME 2022, OPERAT 2021, NF EN ISO 52120-1:2022, Decret tertiaire.', 105, 293, { align: 'center' });

        doc.save('diagnostic-gtb-neogtb.pdf');
        this.emailSent = true;
        setTimeout(() => { this.showEmailModal = false; this.emailSent = false; }, 1500);
        } catch(err) {
          console.error('Erreur génération PDF:', err);
          alert('Erreur lors de la génération du PDF. Vérifiez la console pour plus de détails.');
        }
      },

      resetDiag() {
        this.step = 1;
        this.currentQuestion = 0;
        this.animatedScore = 0;
        this.form = { buildingType: '', surface: null, buildingAge: '', climateZone: '', energies: [{ type: '', conso: null, facture: null }], gtbAnswers: {} };
        this.results = { score: 0, levelKey: 'd', levelLabel: '', levelDescription: '', savingsEuro: 0, savingsPercent: 0, totalConso: 0, totalFacture: 0, energySummary: [], benchmark: { kwhM2: 0, position: 50, refGood: 0, refAvg: 0, refBad: 0, goodPercent: 33, avgPercent: 34, badPercent: 33 }, regulatory: { show: false, severity: 'ok', title: '', text: '', daysLeft: 0 }, recommendations: [] };
        this.errors = {};
        window.scrollTo({ top: 0, behavior: 'smooth' });
      },
    }));
  });
</script>

